---
import '../styles/global.css';
import { instagramUrl } from '../data/social';

interface Props {
	title: string;
	description?: string;
	image?: string;
	robots?: string;
	canonical?: string | URL;
	structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const defaultDescription =
	'Burgerium — born from the Burger Tree legacy. Chennai launch with house-baked buns, flame-grilled burgers, and heritage outlets in Palakkad & Coimbatore.';

const {
	title,
	description = defaultDescription,
	image = `${base}/og-burgerium.png`,
	robots = 'index,follow',
	canonical,
	structuredData: extraStructuredData,
} = Astro.props;

const site = Astro.site ?? new URL('https://www.burgerium.in');
const siteUrl = site.href.replace(/\/$/, '');
const canonicalTarget = canonical instanceof URL ? canonical.href : canonical ?? Astro.url.pathname;
const canonicalURL = new URL(canonicalTarget, site);
const ogImageURL = new URL(image, site);
const logoURL = new URL(`${base}/logo.png`, site);
const isFeedbackRoute = Astro.url.pathname.startsWith('/feedback');

const address = {
	'@type': 'PostalAddress',
	streetAddress: 'E Merck House, Haddows 2nd Street, Nungambakkam',
	addressLocality: 'Chennai',
	addressRegion: 'Tamil Nadu',
	postalCode: '600006',
	addressCountry: 'IN',
};

const menuUrl = `${siteUrl}/menu`;

const additionalStructuredData = Array.isArray(extraStructuredData)
	? extraStructuredData
	: extraStructuredData
		? [extraStructuredData]
		: [];

const defaultStructuredData = isFeedbackRoute
	? []
	: [
			{
				'@type': 'WebSite',
				'@id': `${siteUrl}/#website`,
				url: siteUrl,
				name: 'Burgerium',
				description,
				inLanguage: 'en-IN',
				publisher: { '@id': `${siteUrl}/#restaurant` },
			},
			{
				'@type': 'Restaurant',
				'@id': `${siteUrl}/#restaurant`,
				name: 'Burgerium',
				url: siteUrl,
				logo: logoURL.href,
				image: [ogImageURL.href],
				description,
				servesCuisine: ['Burgers', 'Coffee', 'Desserts', 'Shakes'],
				address,
				areaServed: 'Chennai, Tamil Nadu',
				hasMenu: menuUrl,
				menu: menuUrl,
				sameAs: [instagramUrl],
				mainEntityOfPage: canonicalURL.href,
			},
			{
				'@type': 'WebPage',
				'@id': `${canonicalURL.href}#webpage`,
				url: canonicalURL.href,
				name: title,
				description,
				isPartOf: { '@id': `${siteUrl}/#website` },
				about: { '@id': `${siteUrl}/#restaurant` },
				inLanguage: 'en-IN',
			},
		];

const structuredDataGraph = [...defaultStructuredData, ...additionalStructuredData];
const structuredData = structuredDataGraph.length
	? {
			'@context': 'https://schema.org',
			'@graph': structuredDataGraph,
		}
	: null;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
		<meta name="theme-color" content="#FAA227" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="robots" content={robots} />
		<link rel="icon" type="image/png" href={`${base}/favicon.png`} />
		<link rel="canonical" href={canonicalURL.href} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Google Tag Manager -->
        <script>
            // @ts-nocheck
			(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
			new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
			j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
			'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
			})(window,document,'script','dataLayer','GTM-PS3KLMLZ');
		</script>
		<!-- End Google Tag Manager -->

		<meta property="og:site_name" content="Burgerium" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:image" content={ogImageURL.href} />
		<meta property="og:image:alt" content="Burgerium logo on brand orange" />
		<meta property="og:locale" content="en_IN" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL.href} />
		<meta name="twitter:image:alt" content="Burgerium logo on brand orange" />

		{structuredData && (
			<script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
		)}

        <!-- Preconnect for performance -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="preconnect" href="https://cdnjs.cloudflare.com">

        <!-- Preload critical assets -->
        <link rel="preload" href={`${base}/logo.png`} as="image">

        <!-- Google Fonts with display swap -->
        <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">

        <!-- Icons -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

        <noscript>
            <style>
                #preloader { display: none !important; }
            </style>
        </noscript>
	</head>
	<body class:list={{ 'route-feedback': isFeedbackRoute }}>
		<!-- Google Tag Manager (noscript) -->
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PS3KLMLZ"
		height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		<!-- End Google Tag Manager (noscript) -->
        <!-- Skip to main content for accessibility -->
        <a href="#main-content" class="skip-link">Skip to main content</a>

        {!isFeedbackRoute && (
            <div id="preloader" aria-hidden="true">
                <div class="loader-content">
                    <img src={`${base}/logo.png`} alt="" class="loader-logo">
                    <div class="loader-bar" role="progressbar" aria-label="Loading"><div class="bar-fill"></div></div>
                </div>
            </div>
        )}

        <main id="main-content">
            <slot />
        </main>

        {!isFeedbackRoute && (
            <script src="https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.29/bundled/lenis.min.js"></script>
        )}

        <script is:inline define:vars={{ isFeedbackRoute }}>
            // @ts-nocheck
            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            const canHover = window.matchMedia('(hover: hover)').matches;

            if (!prefersReducedMotion) {
                document.documentElement.classList.add('reveal-enabled');
            }

            // PRELOADER LOGIC
            const preloader = document.getElementById('preloader');
            let preloaderHidden = false;
            let hasSeenPreloader = false;

            try {
                hasSeenPreloader = window.sessionStorage.getItem('burgerium-preloader') === '1';
            } catch {
                hasSeenPreloader = false;
            }

            const markPreloaderSeen = () => {
                try {
                    window.sessionStorage.setItem('burgerium-preloader', '1');
                } catch {}
            };

            const hidePreloader = (delay = 0) => {
                if (!preloader || preloaderHidden) return;
                preloaderHidden = true;

                const run = () => {
                    preloader.classList.add('fade-out');
                    setTimeout(() => preloader.style.display = 'none', 360);
                };

                if (delay > 0) {
                    setTimeout(run, delay);
                } else {
                    run();
                }
            };

            if (!isFeedbackRoute) {
                if (prefersReducedMotion || hasSeenPreloader) {
                    hidePreloader();
                } else if (document.readyState === 'complete') {
                    markPreloaderSeen();
                    hidePreloader(120);
                } else {
                    window.addEventListener('load', () => {
                        markPreloaderSeen();
                        hidePreloader(120);
                    }, { once: true });
                    setTimeout(() => {
                        markPreloaderSeen();
                        hidePreloader();
                    }, 1600);
                }
            }

            // SMOOTH SCROLL (LENIS)
            const LenisClass = globalThis['Lenis'];

            if (!isFeedbackRoute && !prefersReducedMotion && typeof LenisClass !== 'undefined') {
                const lenis = new LenisClass({
                    duration: 1.2,
                    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
                    direction: 'vertical',
                    gestureDirection: 'vertical',
                    smooth: true,
                    mouseMultiplier: 1,
                    smoothTouch: false,
                    touchMultiplier: 2,
                });

                function raf(time) {
                    lenis.raf(time);
                    requestAnimationFrame(raf);
                }
                requestAnimationFrame(raf);
            }

            // MAGNETIC BUTTONS
            const btns = isFeedbackRoute ? [] : Array.from(document.querySelectorAll('.btn-primary'));
            if (canHover && !prefersReducedMotion) {
                btns.forEach((btn) => {
                    if (!(btn instanceof HTMLElement)) return;

                    btn.addEventListener('mousemove', (event) => {
                        if (!(event instanceof MouseEvent)) return;

                        const position = btn.getBoundingClientRect();
                        const x = event.clientX - position.left - position.width / 2;
                        const y = event.clientY - position.top - position.height / 2;

                        btn.style.transform = `translate3d(${x * 0.08}px, ${y * 0.12}px, 0) scale(1.02)`;
                    });

                    btn.addEventListener('mouseleave', () => {
                        btn.style.transform = 'translate3d(0px, 0px, 0) scale(1)';
                    });
                });
            }

            // SCROLL REVEAL (Existing logic preserved/enhanced)
            const revealElements = document.querySelectorAll('.scroll-reveal');

            if (!('IntersectionObserver' in window) || prefersReducedMotion) {
                revealElements.forEach((el) => el.classList.add('active'));
            } else {
                const observer = new IntersectionObserver(
                    (entries) => {
                        entries.forEach((entry) => {
                            if (entry.isIntersecting) {
                                entry.target.classList.add('active');
                                observer.unobserve(entry.target);
                            }
                        });
                    },
                    { rootMargin: '0px 0px -10% 0px', threshold: 0 } // Adjusted threshold for tighter reveal
                );
                revealElements.forEach((el) => observer.observe(el));
            }
        </script>

        <style>
            /* Preloader Styles */
            #preloader {
                position: fixed;
                top: 0; left: 0;
                width: 100%; height: 100%;
                background:
                    radial-gradient(circle at 18% 18%, rgba(255, 247, 229, 0.24), transparent 28%),
                    radial-gradient(circle at 82% 16%, rgba(38, 24, 11, 0.14), transparent 24%),
                    var(--brand-orange);
                display: flex;
                justify-content: center;
                align-items: center;
                z-index: 9999;
                transition: opacity 0.36s ease, visibility 0.36s ease;
            }

            .loader-content {
                text-align: center;
            }

            .loader-logo {
                width: 160px;
                height: auto;
                opacity: 0;
                animation: fadeUp 0.8s forwards;
                filter: drop-shadow(0 16px 24px rgba(93, 60, 10, 0.18));
            }

            .loader-bar {
                width: 156px;
                height: 4px;
                background: rgba(38, 24, 11, 0.2);
                margin: 18px auto 0;
                position: relative;
                overflow: hidden;
                border-radius: 999px;
            }

            .bar-fill {
                position: absolute;
                top: 0; left: 0;
                width: 0%; height: 100%;
                background: linear-gradient(90deg, var(--brand-ink), var(--brand-orange-deep));
                border-radius: 999px;
                animation: fillBar 0.9s ease-in-out forwards;
            }

            .fade-out {
                opacity: 0;
                pointer-events: none;
            }

            @keyframes fadeUp {
                from { opacity: 0; transform: translateY(20px); }
                to { opacity: 1; transform: translateY(0); }
            }

            @keyframes fillBar {
                0% { width: 0%; }
                100% { width: 100%; }
            }

            /* Scrollbar Hide (Let Lenis handle it visually, optional but clean) */
            html.lenis {
                height: auto;
            }
            .lenis.lenis-smooth {
                scroll-behavior: auto;
            }
            .lenis.lenis-smooth [data-lenis-prevent] {
                overscroll-behavior: contain;
            }
            .lenis.lenis-stopped {
                overflow: hidden;
            }
            .lenis.lenis-scrolling iframe {
                pointer-events: none;
            }
        </style>
	</body>
</html>
