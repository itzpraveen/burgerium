---
import { menuItemCount, menuSectionCount, menuSections } from "../data/menu";

const previewSectionSlugs = [
  "signature-burgers",
  "fries-starters",
  "veg-burgers",
  "milkshakes",
];

const previewSections = previewSectionSlugs
  .map((slug) => menuSections.find((section) => section.slug === slug))
  .filter(Boolean);

const getItems = (section) => section.blocks.flatMap((block) => block.items);
---

<section id="menu" class="menu-preview" aria-labelledby="menu-preview-heading">
  <div class="container menu-preview-shell">
    <div class="menu-preview-copy scroll-reveal">
      <span class="menu-kicker">Digital Menu</span>
      <h2 id="menu-preview-heading">
        The menu is easier to browse now.
      </h2>
      <p class="menu-copy">
        Check sections, prices, and a few crowd favourites before you visit.
      </p>

      <div class="menu-stats" aria-label="Menu highlights">
        <article class="stat-card">
          <strong>{menuItemCount}</strong>
          <span>Menu items</span>
        </article>
        <article class="stat-card">
          <strong>{menuSectionCount}</strong>
          <span>Sections</span>
        </article>
        <article class="stat-card">
          <strong>20-25</strong>
          <span>Minutes fresh prep</span>
        </article>
      </div>

      <div class="menu-actions">
        <a class="btn-primary" href="/menu">Open Full Menu</a>
        <a class="btn-secondary" href="#locations">Find Chennai House</a>
      </div>

      <p class="menu-meta">
        Prices exclude GST. Food is prepared once you order.
      </p>
    </div>

    <div class="preview-grid">
      {previewSections.map((section, index) => {
        const items = getItems(section);
        const minPrice = Math.min(...items.map((item) => item.price));
        const samples = items.slice(0, 3);

        return (
          <a
            href={`/menu#${section.slug}`}
            class="preview-card scroll-reveal"
            style={`--delay:${index * 0.08}s`}
          >
            <div class="preview-card-top">
              <span class="preview-label">{section.label}</span>
              <span class="preview-price">From Rs {minPrice}</span>
            </div>

            <h3>{section.title}</h3>

            <p class="preview-count">
              {items.length} items in this section
            </p>

            <ul class="preview-list">
              {samples.map((item) => (
                <li>{item.name}</li>
              ))}
            </ul>

            <span class="preview-link">
              See section
              <i class="fas fa-arrow-right" aria-hidden="true"></i>
            </span>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .menu-preview {
    position: relative;
    padding: 7rem 0;
    background:
      radial-gradient(circle at top left, rgba(250, 162, 39, 0.16), transparent 32%),
      linear-gradient(180deg, #fff8e8 0%, #ffe4a7 100%);
    overflow: hidden;
  }

  .menu-preview::before {
    content: "";
    position: absolute;
    inset: 2rem auto auto 50%;
    width: min(620px, 72vw);
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(250, 162, 39, 0.55), transparent);
    transform: translateX(-50%);
  }

  .menu-preview-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .menu-preview-copy {
    position: sticky;
    top: calc(var(--header-height) + 2rem);
    padding: 2rem 2.2rem;
    border: 1px solid var(--line-soft);
    background: rgba(255, 249, 236, 0.92);
    box-shadow: var(--shadow-soft);
  }

  .menu-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.9rem;
    margin-bottom: 1.25rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #111;
    background: var(--brand-orange);
  }

  .menu-preview-copy h2 {
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    line-height: 0.92;
    max-width: 12ch;
  }

  .menu-copy,
  .menu-meta {
    max-width: 58ch;
    color: var(--text-gray);
    line-height: 1.7;
  }

  .menu-copy {
    margin-top: 1.35rem;
    font-size: 1.02rem;
  }

  .menu-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
    margin: 2rem 0 1.5rem;
  }

  .stat-card {
    padding: 1rem;
    border: 1px solid var(--line-soft);
    background: rgba(255, 255, 255, 0.46);
  }

  .stat-card strong {
    display: block;
    margin-bottom: 0.25rem;
    font-family: var(--font-heading);
    font-size: 2rem;
    line-height: 1;
    color: var(--brand-orange);
  }

  .stat-card span {
    display: block;
    color: var(--text-gray);
    font-size: 0.86rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .menu-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-bottom: 1rem;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 58px;
    padding: 1rem 1.6rem;
    border: 1px solid var(--line-strong);
    color: var(--text-white);
    font-family: var(--font-heading);
    font-size: 1.05rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease;
  }

  .btn-secondary:hover {
    transform: translateY(-2px);
    border-color: var(--brand-orange);
    background: rgba(250, 162, 39, 0.08);
  }

  .preview-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .preview-card {
    min-height: 280px;
    padding: 1.4rem;
    border: 1px solid var(--line-soft);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.66), rgba(255, 255, 255, 0.36)),
      linear-gradient(160deg, rgba(250, 162, 39, 0.12), transparent 48%);
    transition:
      transform 0.32s ease,
      border-color 0.32s ease,
      box-shadow 0.32s ease;
    transition-delay: var(--delay, 0s);
  }

  .preview-card:hover {
    transform: translateY(-8px);
    border-color: rgba(250, 162, 39, 0.65);
    box-shadow: var(--shadow-soft);
  }

  .preview-card-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1.25rem;
  }

  .preview-label,
  .preview-price {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0.28rem 0.7rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .preview-label {
    color: #111;
    background: var(--brand-orange);
  }

  .preview-price {
    color: var(--brand-orange-deep);
    background: rgba(250, 162, 39, 0.12);
  }

  .preview-card h3 {
    font-size: clamp(1.6rem, 2.5vw, 2rem);
    line-height: 1;
    margin-bottom: 0.7rem;
  }

  .preview-count {
    color: var(--text-gray);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .preview-list {
    list-style: none;
    display: grid;
    gap: 0.55rem;
    margin-bottom: 1.2rem;
  }

  .preview-list li {
    position: relative;
    padding-left: 1rem;
    color: var(--text-white);
  }

  .preview-list li::before {
    content: "";
    position: absolute;
    top: 0.55rem;
    left: 0;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 50%;
    background: var(--brand-orange);
  }

  .preview-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--brand-orange);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.82rem;
  }

  .preview-link i {
    transition: transform 0.25s ease;
  }

  .preview-card:hover .preview-link i {
    transform: translateX(4px);
  }

  @media (max-width: 1150px) {
    .menu-preview-shell {
      grid-template-columns: 1fr;
    }

    .menu-preview-copy {
      position: relative;
      top: auto;
    }
  }

  @media (max-width: 720px) {
    .menu-preview {
      padding: 5rem 0;
    }

    .menu-preview-shell {
      gap: 1.25rem;
    }

    .menu-preview-copy {
      padding: 1.4rem;
      border-radius: 26px;
    }

    .menu-preview-copy h2 {
      max-width: none;
      font-size: clamp(2.2rem, 12vw, 3.2rem);
    }

    .preview-grid {
      grid-template-columns: 1fr;
    }

    .menu-stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.55rem;
      margin: 1.5rem 0 1.25rem;
    }

    .stat-card {
      padding: 0.8rem 0.65rem;
      text-align: center;
    }

    .stat-card strong {
      font-size: 1.45rem;
    }

    .stat-card span {
      font-size: 0.68rem;
      letter-spacing: 0.05em;
    }

    .menu-actions {
      flex-direction: column;
    }

    .btn-secondary,
    .menu-actions :global(.btn-primary) {
      width: 100%;
      justify-content: center;
    }

    .preview-card {
      min-height: 0;
      padding: 1.2rem;
      border-radius: 24px;
    }

    .preview-card-top {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.65rem;
    }

    .preview-card h3 {
      font-size: 1.7rem;
    }

    .preview-list {
      gap: 0.45rem;
      margin-bottom: 1rem;
    }
  }

  @media (max-width: 520px) {
    .preview-label,
    .preview-price {
      min-height: 30px;
      padding: 0.24rem 0.6rem;
      font-size: 0.68rem;
    }
  }
</style>
