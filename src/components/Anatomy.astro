---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="anatomy-section">
    <div class="container">
        <div class="anatomy-header text-center">
            <span class="eyebrow">Layer By Layer</span>
            <h2 class="title">What Makes It <span class="text-orange">Work</span></h2>
            <p class="subtitle">A good burger is balance. Bun, crunch, sauce, melt, and patty all need to do their job.</p>
        </div>

        <div class="anatomy-grid">
            <!-- Left Labels -->
            <div class="labels-col left">
                <div class="label-item scroll-reveal slide-right">
                    <h3>The Bun</h3>
                    <p>Soft brioche, toasted just enough to hold everything together.</p>
                </div>
                <div class="label-item scroll-reveal slide-right delay-100">
                    <h3>The Crunch</h3>
                    <p>Lettuce and tomato for freshness, bite, and balance.</p>
                </div>
                <div class="label-item scroll-reveal slide-right delay-200">
                    <h3>The Melt</h3>
                    <p>Cheese that melts into the burger instead of just sitting on top.</p>
                </div>
            </div>

            <!-- Center Image -->
            <div class="visual-col">
                <img src={`${base}/burger_exploded.png`} alt="Deconstructed Burger" class="exploded-img float-anim">
            </div>

            <!-- Right Labels -->
            <div class="labels-col right">
                <div class="label-item scroll-reveal slide-left delay-100">
                    <h3>The Patty</h3>
                    <p>The centre of the burger, cooked for colour, texture, and a proper sear.</p>
                </div>
                <div class="label-item scroll-reveal slide-left delay-200">
                    <h3>The Sauce</h3>
                    <p>The house layer that ties the whole thing together.</p>
                </div>
                <div class="label-item scroll-reveal slide-left delay-300">
                    <h3>The Hold</h3>
                    <p>A base bun that stays soft without falling apart halfway through.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .anatomy-section {
        background: radial-gradient(circle at center, #fff8ea 0%, #ffe1a4 72%);
        padding: 8rem 0;
        overflow: hidden;
    }

    .anatomy-header {
        margin-bottom: 5rem;
        text-align: center;
    }

    .eyebrow {
        color: var(--brand-orange);
        text-transform: uppercase;
        letter-spacing: 3px;
        font-size: 0.9rem;
    }

    .title {
        font-size: 3.5rem;
        margin: 1rem 0;
        color: var(--text-white);
    }

    .subtitle {
        color: var(--text-muted);
        font-size: 1.2rem;
        max-width: 600px;
        margin: 0 auto;
    }

    .anatomy-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr 1fr;
        align-items: center;
        gap: 2rem;
    }

    .exploded-img {
        width: 100%;
        filter: drop-shadow(0 20px 40px rgba(0,0,0,0.5));
        transform: scale(1.1);
    }

    .label-item {
        margin-bottom: 4rem;
        position: relative;
        padding: 1.1rem 1.25rem;
        border: 1px solid var(--line-soft);
        background: rgba(255, 249, 237, 0.7);
        box-shadow: var(--shadow-soft);
    }

    .label-item h3 {
        color: var(--text-white);
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
    }

    .label-item p {
        color: var(--text-gray);
        font-size: 0.95rem;
    }

    /* Directional Styling */
    .left .label-item { text-align: right; }
    .right .label-item { text-align: left; }

    /* Connecting Lines (Pseudo-elements) */
    .left .label-item::after, .right .label-item::after {
        content: '';
        position: absolute;
        top: 50%;
        width: 60px;
        height: 1px;
        background: var(--brand-orange);
        opacity: 0.5;
    }

    .left .label-item::after { right: -80px; }
    .right .label-item::after { left: -80px; }

    @media (max-width: 900px) {
        .anatomy-grid {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 3rem; /* More space between items */
        }

        .visual-col {
            order: -1; /* Image first */
            margin-bottom: 2rem;
        }

        .left .label-item, .right .label-item {
            text-align: center;
            margin-bottom: 2rem;
            padding: 0 1rem;
        }

        /* Hide connecting lines on mobile */
        .left .label-item::after, .right .label-item::after {
            display: none;
        }
        
        .exploded-img {
            transform: scale(1);
            max-width: 85%;
        }
    }
</style>
