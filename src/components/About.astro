---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const timeline = [
    {
        logo: 'burgertree_logo.png',
        logoAlt: 'Konari Breads and Cakes logo',
        title: 'Bakery Roots',
        year: '1998',
        location: 'Calicut',
        isNew: false
    },
    {
        logo: 'burgertree_logo.png',
        logoAlt: 'Burger Tree logo',
        title: 'Burger Tree',
        year: '2017',
        location: 'Kerala & Tamil Nadu',
        isNew: false
    },
    {
        logo: 'logo.png',
        logoAlt: 'Burgerium logo',
        title: 'Burgerium',
        year: '2025',
        location: 'Chennai Launch',
        isNew: true
    }
];

const houseNotes = [
    {
        title: 'Bakery First',
        detail: 'The dough story started long before Burgerium, and you can feel it in every bun.'
    },
    {
        title: 'Made For Chennai',
        detail: 'Burgerium brings those bakery roots to Chennai with its own burgers, sides, and flavour.'
    },
    {
        title: 'The Full Table',
        detail: 'Burgers lead the way, with fries, coffee, shakes, and sides ready to round out the table.'
    }
];
---

<section id="about" class="section-padding about-section" aria-labelledby="about-heading">
    <div class="container">
        <div class="grid-layout">
            <!-- Left: Visual Stack -->
            <div class="visual-col scroll-reveal">
                <div class="img-frame">
                    <img
                        src={`${base}/hero_feast.png`}
                        alt="Burgerium signature spread featuring gourmet burgers and sides"
                        class="main-img"
                        loading="lazy"
                    />
                    <div class="stat-box" aria-label="25 plus years of legacy">
                        <span class="stat-num">25+</span>
                        <span class="stat-label">Years of <br/>Legacy</span>
                    </div>
                </div>
            </div>

            <!-- Right: Story -->
            <div class="content-col scroll-reveal delay-200">
                <span class="badge">Our Story</span>
                <h2 class="section-title" id="about-heading">From Bakery Roots To <span class="text-orange">Burgerium</span></h2>

                <p class="story-text">
                    <strong>Burgerium</strong> comes from the same family behind <strong>Konari Breads</strong> and <strong>Burger Tree</strong>. The bakery began in 1998, Burger Tree followed in 2017, and Burgerium brings those roots to Chennai.
                </p>

                <div class="house-notes" aria-label="What defines Burgerium">
                    {houseNotes.map((note) => (
                        <article class="house-note">
                            <strong>{note.title}</strong>
                            <p>{note.detail}</p>
                        </article>
                    ))}
                </div>

                <div class="timeline-box" role="list" aria-label="Company timeline">
                    {timeline.map((item, index) => (
                        <>
                            <div class="timeline-step" role="listitem">
                                <div class={`step-icon ${item.isNew ? 'new-logo' : 'old-logo'}`}>
                                    <img src={`${base}/${item.logo}`} alt={item.logoAlt} loading="lazy" />
                                </div>
                                <div class="step-info">
                                    <h4>{item.title}</h4>
                                    <span>{item.year} • {item.location}</span>
                                </div>
                            </div>
                            {index < timeline.length - 1 && (
                                <div class="connector-line" aria-hidden="true"></div>
                            )}
                        </>
                    ))}
                </div>

                <p class="story-footer">
                    From <strong>Urban Eats and Kitchen LLP</strong>, with bakery roots going back to 1998.
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    .about-section {
        background: linear-gradient(180deg, #fff8ea 0%, var(--bg-surface) 100%);
    }

    .grid-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
        align-items: center;
    }

    .img-frame {
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: var(--shadow-soft);
    }

    .main-img {
        width: 100%;
        aspect-ratio: 4/3;
        object-fit: cover;
        filter: grayscale(20%) contrast(110%);
        transition: filter 0.5s ease, transform 0.5s ease;
    }

    .img-frame:hover .main-img {
        filter: grayscale(0%);
        transform: scale(1.05);
    }

    .stat-box {
        position: absolute;
        bottom: 0;
        left: 0;
        background: var(--brand-orange);
        padding: 1.5rem 2rem;
        color: #000;
    }

    .stat-num {
        display: block;
        font-family: var(--font-heading);
        font-size: clamp(2.5rem, 4vw, 3.5rem);
        line-height: 1;
    }

    .stat-label {
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
    }

    .story-text {
        font-size: 1.1rem;
        color: var(--text-gray);
        margin-bottom: 2.5rem;
        line-height: 1.7;
    }

    .story-text strong {
        color: var(--text-white);
    }

    .house-notes {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.9rem;
        margin-bottom: 2rem;
    }

    .house-note {
        padding: 1rem 1rem 1.1rem;
        border-radius: 18px;
        background: rgba(255, 250, 241, 0.88);
        border: 1px solid var(--line-soft);
        box-shadow: 0 12px 24px rgba(96, 61, 10, 0.05);
    }

    .house-note strong {
        display: block;
        margin-bottom: 0.45rem;
        color: var(--text-white);
        font-family: var(--font-heading);
        font-size: 1rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .house-note p {
        margin: 0;
        color: var(--text-gray);
        font-size: 0.92rem;
        line-height: 1.55;
    }

    /* Timeline Stylization */
    .timeline-box {
        background: rgba(255, 250, 241, 0.9);
        padding: 1.5rem 2rem;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        border: 1px solid var(--line-soft);
        flex-wrap: wrap;
    }

    .timeline-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 0.75rem;
        padding: 0.5rem;
        min-width: 100px;
    }

    .step-icon {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        background: rgba(250, 162, 39, 0.12);
        transition: transform 0.3s ease;
    }

    .timeline-step:hover .step-icon {
        transform: scale(1.1);
    }

    .step-icon img {
        height: 35px;
        width: auto;
        max-width: 50px;
        object-fit: contain;
    }

    .new-logo {
        background: var(--brand-orange) !important;
    }

    .new-logo img {
        filter: none;
    }

    .step-info h4 {
        font-size: 0.95rem;
        color: var(--text-white);
        margin: 0;
        font-family: var(--font-body);
        font-weight: 700;
    }

    .step-info span {
        font-size: 0.7rem;
        color: var(--text-gray);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .connector-line {
        width: 40px;
        height: 2px;
        background: linear-gradient(90deg, var(--brand-orange) 0%, rgba(250, 162, 39, 0.3) 100%);
        margin: 0 0.75rem;
        position: relative;
        flex-shrink: 0;
    }

    .connector-line::after {
        content: '';
        position: absolute;
        right: -3px;
        top: -3px;
        width: 0;
        height: 0;
        border-top: 4px solid transparent;
        border-bottom: 4px solid transparent;
        border-left: 6px solid var(--brand-orange);
    }

    .story-footer {
        margin-top: 2rem;
        font-style: italic;
        color: var(--brand-orange-deep);
        font-size: 0.95rem;
    }

    .story-footer strong {
        font-style: normal;
    }

    @media (max-width: 1024px) {
        .grid-layout {
            gap: 4rem;
        }

        .timeline-box {
            padding: 1.25rem;
        }

        .connector-line {
            width: 25px;
            margin: 0 0.5rem;
        }

        .timeline-step {
            min-width: 80px;
        }
    }

    @media (max-width: 900px) {
        .grid-layout {
            grid-template-columns: 1fr;
            gap: 3rem;
        }

        .visual-col {
            order: 2;
        }

        .content-col {
            order: 1;
        }

        .img-frame {
            max-height: 350px;
        }

        .main-img {
            height: 100%;
        }

        .house-notes {
            grid-template-columns: 1fr;
        }

        .timeline-box {
            width: 100%;
            justify-content: space-around;
            padding: 1.5rem 1rem;
        }

        .connector-line {
            width: 20px;
            margin: 0 0.25rem;
        }

        .timeline-step {
            min-width: 70px;
        }

        .step-icon {
            width: 50px;
            height: 50px;
        }

        .step-icon img {
            height: 28px;
        }

        .step-info h4 {
            font-size: 0.85rem;
        }

        .step-info span {
            font-size: 0.65rem;
        }
    }

    @media (max-width: 500px) {
        .timeline-box {
            flex-direction: column;
            gap: 1rem;
        }

        .connector-line {
            width: 2px;
            height: 20px;
            margin: 0;
            background: linear-gradient(180deg, var(--brand-orange) 0%, rgba(250, 162, 39, 0.3) 100%);
        }

        .connector-line::after {
            right: -3px;
            top: auto;
            bottom: -3px;
            border-top: 6px solid var(--brand-orange);
            border-left: 4px solid transparent;
            border-right: 4px solid transparent;
            border-bottom: none;
        }

        .timeline-step {
            flex-direction: row;
            gap: 1rem;
            width: 100%;
            justify-content: flex-start;
            text-align: left;
        }

        .step-info {
            text-align: left;
        }
    }
</style>
