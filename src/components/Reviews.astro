---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="reviews-section" style={`--reviews-bg: url('${base}/bg.png')`}>
    <div class="container">
        <h2 class="section-title center">What <span class="text-orange">Regulars</span> Remember</h2>
        
        <div class="reviews-grid">
            <!-- Review 1 -->
            <div class="review-card scroll-reveal">
                <div class="stars">★★★★★</div>
                <p class="review-text">"The bun is what I remember first. Soft, light, and built for a proper burger."</p>
                <div class="reviewer">
                    <div class="avatar">A</div>
                    <div class="details">
                        <strong>Arjun Nair</strong>
                        <small>Heritage Regular</small>
                    </div>
                </div>
            </div>

            <!-- Review 2 -->
            <div class="review-card scroll-reveal delay-100">
                <div class="stars">★★★★★</div>
                <p class="review-text">"I would drive just for the loaded fries. If Chennai gets the same food, people are going to line up."</p>
                <div class="reviewer">
                    <div class="avatar">D</div>
                    <div class="details">
                        <strong>Divya S.</strong>
                        <small>Food Blogger</small>
                    </div>
                </div>
            </div>

            <!-- Review 3 -->
            <div class="review-card scroll-reveal delay-200">
                <div class="stars">★★★★★</div>
                <p class="review-text">"It tastes like people in the kitchen actually care about what goes out. That is rarer than it should be."</p>
                <div class="reviewer">
                    <div class="avatar">R</div>
                    <div class="details">
                        <strong>Rahul Krishnan</strong>
                        <small>RS Puram Fan</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .reviews-section {
        padding: 5rem 0;
        background: var(--reviews-bg, url('/bg.png')) center/cover no-repeat;
        position: relative;
    }

    @media (min-width: 900px) and (prefers-reduced-motion: no-preference) {
        .reviews-section {
            background-attachment: fixed;
        }
    }

    .reviews-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(255, 246, 223, 0.92), rgba(250, 186, 73, 0.72));
    }

    .section-title {
        position: relative;
        z-index: 2;
        margin-bottom: 4rem;
        text-align: center;
    }

    .reviews-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        position: relative;
        z-index: 2;
    }

    .review-card {
        background: rgba(255, 250, 240, 0.78);
        backdrop-filter: blur(10px);
        padding: 2rem;
        border-radius: 16px;
        border: 1px solid rgba(105, 65, 5, 0.12);
        box-shadow: var(--shadow-soft);
    }

    .stars {
        color: var(--brand-orange);
        font-size: 1.2rem;
        margin-bottom: 1rem;
    }

    .review-text {
        color: var(--text-gray);
        font-style: italic;
        margin-bottom: 1.5rem;
        line-height: 1.6;
        min-height: 80px;
    }

    .reviewer {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .avatar {
        width: 40px; height: 40px;
        background: var(--brand-orange);
        color: #000;
        border-radius: 50%;
        display: grid;
        place-items: center;
        font-weight: 700;
    }

    .details strong { display: block; color: var(--text-white); }
    .details small { color: var(--text-muted); }
</style>
