---
import { instagramHandle, instagramUrl } from '../data/social';

const locations = [
    {
        city: 'Chennai',
        name: 'Nungambakkam',
        address: ['E Merck House', 'Haddows 2nd Street', 'Nungambakkam', 'Chennai-600006'],
        phone: null,
        map: null,
        comingSoon: true,
        launchDate: 'Opening Updates'
    }
];
---

<section id="locations" class="section-padding locations-section" aria-labelledby="locations-heading">
    <div class="container">
        <div class="locations-head scroll-reveal">
            <div class="head-content">
                <p class="eyebrow">Chennai House</p>
                <h2 class="section-title" id="locations-heading">Find Burgerium In <span class="text-orange">Nungambakkam</span></h2>
                <p class="lede">
                    Find Burgerium at E Merck House, Haddows 2nd Street, Nungambakkam. Follow Instagram for opening dates, timings, and updates.
                </p>
            </div>
        </div>

        <div class="location-facts scroll-reveal delay-100" aria-label="Burgerium location facts">
            <article>
                <strong>Chennai Address</strong>
                <span>E Merck House, Haddows 2nd Street, Nungambakkam.</span>
            </article>
            <article>
                <strong>Menu &amp; Prices</strong>
                <span>See the menu and prices before you visit.</span>
            </article>
            <article>
                <strong>Latest Updates</strong>
                <span>Opening dates and timings will appear on Instagram first.</span>
            </article>
        </div>

        <div class="locations-grid" role="list">
            {locations.map((loc) => (
                <article class={`location-card scroll-reveal ${loc.comingSoon ? 'coming-soon' : ''}`} role="listitem">
                    {loc.comingSoon && (
                        <div class="coming-soon-badge">
                            <i class="fas fa-clock" aria-hidden="true"></i>
                            <span>{loc.launchDate}</span>
                        </div>
                    )}
                    <div class="card-top">
                        <span class="pill">{loc.city}</span>
                        <h3>{loc.name}</h3>
                        <p class="address">
                            {loc.address.map((line) => (
                                <>
                                    {line}<br />
                                </>
                            ))}
                        </p>
                    </div>

                    {loc.comingSoon ? (
                        <div class="card-actions coming-soon-actions">
                            <div class="notify-box">
                                <p class="notify-text">Follow Instagram for opening dates and timings</p>
                                <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="btn-primary btn-notify">
                                    <i class="fab fa-instagram" aria-hidden="true"></i>
                                    Follow {instagramHandle}
                                </a>
                            </div>
                        </div>
                    ) : (
                        <div class="card-actions">
                            <a class="btn-primary" href={loc.map} target="_blank" rel="noopener noreferrer">
                                Get Directions
                                <i class="fas fa-arrow-right" aria-hidden="true"></i>
                            </a>
                            {loc.phone && (
                                <a class="phone" href={`tel:${loc.phone.replace(/\s+/g, '')}`}>
                                    <i class="fas fa-phone" aria-hidden="true"></i>
                                    {loc.phone}
                                </a>
                            )}
                        </div>
                    )}
                </article>
            ))}
        </div>

        <!-- Expansion teaser -->
        <div class="expansion-teaser scroll-reveal delay-200">
            <div class="teaser-content">
                <i class="fas fa-map-marker-alt" aria-hidden="true"></i>
                <p>More Burgerium locations are planned for <strong>Kerala</strong> and <strong>Karnataka</strong>.</p>
            </div>
        </div>
    </div>
</section>

<style>
    .locations-section {
        background: linear-gradient(180deg, #ffe7b3 0%, #fff6e1 100%);
    }

    .locations-head {
        text-align: center;
        margin-bottom: 3rem;
    }

    .eyebrow {
        letter-spacing: 3px;
        text-transform: uppercase;
        font-size: 0.85rem;
        color: var(--brand-orange);
        margin-bottom: 0.5rem;
        font-weight: 600;
    }

    .lede {
        color: var(--text-gray);
        margin: 1rem auto 0;
        line-height: 1.7;
        max-width: 500px;
        font-size: 1.05rem;
    }

    .locations-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 1.5rem;
        max-width: 800px;
        margin: 0 auto;
    }

    .location-facts {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        max-width: 980px;
        margin: 0 auto 1.5rem;
    }

    .location-facts article {
        padding: 1.15rem 1.2rem;
        border-radius: 20px;
        background: rgba(255, 249, 236, 0.72);
        border: 1px solid rgba(157, 93, 0, 0.12);
        box-shadow: 0 12px 24px rgba(75, 47, 10, 0.05);
    }

    .location-facts strong {
        display: block;
        margin-bottom: 0.35rem;
        color: var(--text-white);
        font-family: var(--font-heading);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: 0.95rem;
    }

    .location-facts span {
        color: var(--text-gray);
        line-height: 1.55;
        font-size: 0.94rem;
    }

    .location-card {
        background: rgba(255, 249, 238, 0.94);
        border: 1px solid var(--line-soft);
        border-radius: 28px;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        position: relative;
        overflow: hidden;
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

    .location-card:hover {
        border-color: rgba(250, 162, 39, 0.3);
        box-shadow: var(--shadow-soft);
    }

    .location-card::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 80% 0%, rgba(250, 162, 39, 0.1), transparent 50%);
        pointer-events: none;
    }

    .coming-soon-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(250, 162, 39, 0.16);
        color: var(--brand-orange-deep);
        border: 1px solid rgba(157, 93, 0, 0.12);
        padding: 0.5rem 1rem;
        border-radius: 25px;
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        width: fit-content;
    }

    .card-top {
        position: relative;
        z-index: 2;
    }

    .card-top h3 {
        font-size: clamp(1.5rem, 3vw, 1.8rem);
        margin-bottom: 0.5rem;
        color: var(--text-white);
    }

    .pill {
        display: inline-block;
        padding: 0.35rem 0.75rem;
        border-radius: 999px;
        background: rgba(250, 162, 39, 0.15);
        color: var(--brand-orange);
        font-weight: 700;
        letter-spacing: 1px;
        font-size: 0.75rem;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
    }

    .address {
        color: var(--text-gray);
        line-height: 1.6;
        font-size: 1rem;
    }

    .card-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        position: relative;
        z-index: 2;
    }

    .coming-soon-actions {
        flex-direction: column;
        align-items: stretch;
    }

    .notify-box {
        background: rgba(255, 255, 255, 0.56);
        border: 1px solid rgba(184, 104, 0, 0.16);
        border-radius: 18px;
        padding: 1.25rem;
        text-align: center;
    }

    .notify-text {
        color: var(--text-gray);
        font-size: 0.9rem;
        margin-bottom: 1rem;
    }

    .btn-notify {
        width: 100%;
        justify-content: center;
        gap: 0.75rem;
    }

    .btn-notify i {
        font-size: 1.1rem;
    }

    .card-actions .btn-primary {
        padding: 0.9rem 1.8rem;
        font-size: 0.95rem;
    }

    .phone {
        color: var(--text-white);
        font-weight: 700;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: color 0.3s ease;
    }

    .phone:hover {
        color: var(--brand-orange);
    }

    /* Expansion teaser */
    .expansion-teaser {
        margin-top: 3rem;
        text-align: center;
    }

    .teaser-content {
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        background: rgba(255, 249, 236, 0.75);
        border: 1px solid rgba(250, 162, 39, 0.2);
        padding: 1rem 2rem;
        border-radius: 999px;
        box-shadow: 0 12px 24px rgba(75, 47, 10, 0.05);
    }

    .teaser-content i {
        color: var(--brand-orange);
        font-size: 1.1rem;
    }

    .teaser-content p {
        color: var(--text-gray);
        font-size: 0.95rem;
        margin: 0;
    }

    .teaser-content strong {
        color: var(--brand-orange);
    }

    @media (max-width: 768px) {
        .location-facts {
            grid-template-columns: 1fr;
        }

        .locations-grid {
            grid-template-columns: 1fr;
        }

        .location-card {
            padding: 1.5rem;
        }

        .card-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .card-actions .btn-primary {
            width: 100%;
            justify-content: center;
        }

        .teaser-content {
            flex-direction: column;
            gap: 0.5rem;
            padding: 1.25rem 1.5rem;
            border-radius: 16px;
        }
    }
</style>
