---
import { instagramHandle, instagramUrl } from '../data/social';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname === '' ? '/' : Astro.url.pathname;
const isHomePage = currentPath === '/';
const currentYear = new Date().getFullYear();

const quickLinks = [
    { href: isHomePage ? '#about' : '/#about', label: 'Our Roots' },
    { href: isHomePage ? '#menu' : '/menu', label: 'Menu Highlights' },
    { href: '/guest-feedback', label: 'Guest Feedback' },
    { href: isHomePage ? '#locations' : '/#locations', label: 'Locations' },
];

---

<footer role="contentinfo">
    <!-- Top Bar Call to Action -->
    <div class="footer-cta">
        <div class="container cta-content">
            <h3>Planning a Burgerium visit?</h3>
            <a href={isHomePage ? '#locations' : '/#locations'} class="btn-primary">
                See Chennai House
                <i class="fas fa-arrow-right" aria-hidden="true"></i>
            </a>
        </div>
    </div>

    <!-- Main Footer -->
    <div class="main-footer">
        <div class="container">
            <div class="footer-grid">
                <!-- Brand Col -->
                <div class="f-col brand-col">
                    <img src={`${base}/logo.png`} alt="Burgerium" class="f-logo" loading="lazy" />
                    <p class="legal-line">A Unit of Urban Eats and Kitchen LLP</p>
                    <p class="brand-note">
                        Bakery roots, bold burgers, and a Chennai house worth the trip.
                    </p>
                    <a
                        href={instagramUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="instagram-link"
                        aria-label={`Open Burgerium Instagram ${instagramHandle}`}
                    >
                        <span class="instagram-link-icon" aria-hidden="true">
                            <i class="fab fa-instagram"></i>
                        </span>
                        <span class="instagram-link-copy">
                            <strong>Instagram</strong>
                            <small>{instagramHandle}</small>
                        </span>
                        <i class="fas fa-arrow-up-right-from-square instagram-link-external" aria-hidden="true"></i>
                    </a>
                </div>

                <!-- Locations -->
                <div class="f-col">
                    <h5>Locations</h5>
                    <ul class="f-list" role="list">
                        <li class="active" role="listitem">
                            <span>Chennai</span>
                            <small>Nungambakkam</small>
                        </li>
                    </ul>
                </div>

                <!-- Links -->
                <nav class="f-col" aria-label="Footer navigation">
                    <h5>Quick Links</h5>
                    <ul class="f-list" role="list">
                        {quickLinks.map((link) => (
                            <li role="listitem">
                                <a href={link.href}>{link.label}</a>
                            </li>
                        ))}
                    </ul>
                </nav>
            </div>

            <div class="sub-footer">
                <p>&copy; {currentYear} Burgerium. <strong>A Unit of Urban Eats and Kitchen LLP</strong>.</p>
            </div>
        </div>
    </div>
</footer>

<style>
    /* CTA Bar */
    .footer-cta {
        background: linear-gradient(180deg, #fff1cb 0%, #ffd989 100%);
        padding: 3.6rem 0;
        border-top: 1px solid rgba(0, 0, 0, 0.06);
        border-bottom: 1px solid rgba(0,0,0,0.08);
    }

    .cta-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
    }

    .cta-content h3 {
        color: var(--text-white);
        font-size: clamp(1.6rem, 3vw, 2.3rem);
    }

    .cta-content .btn-primary {
        flex-shrink: 0;
    }

    /* Main Footer */
    .main-footer {
        background: linear-gradient(180deg, #faa227 0%, #ef9618 100%);
        color: var(--brand-ink);
        padding-top: 4rem;
        border-top: 1px solid rgba(38, 24, 11, 0.14);
    }

    .footer-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr;
        gap: 3rem;
        padding-bottom: 3rem;
        border-bottom: 1px solid rgba(38, 24, 11, 0.14);
    }

    .f-logo {
        width: 180px;
        margin-bottom: 1.25rem;
    }

    .brand-col p {
        font-weight: 500;
        margin-bottom: 1rem;
        line-height: 1.6;
    }

    .legal-line {
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        color: rgba(38, 24, 11, 0.66);
        margin-bottom: 1.5rem;
    }

    .brand-note {
        max-width: 24rem;
        color: rgba(38, 24, 11, 0.78);
        margin-bottom: 1.5rem;
    }

    .instagram-link {
        display: inline-flex;
        align-items: center;
        gap: 0.9rem;
        margin-top: 0.25rem;
        color: var(--brand-ink);
        transition: opacity 0.2s ease, transform 0.2s ease;
    }

    .instagram-link:hover {
        opacity: 0.84;
        transform: translateY(-1px);
    }

    .instagram-link-icon {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: rgba(38, 24, 11, 0.92);
        color: #fff5e5;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
    }

    .instagram-link-copy {
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    .instagram-link-copy strong {
        font-family: var(--font-heading);
        font-size: 1.05rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        line-height: 1;
    }

    .instagram-link-copy small {
        margin-top: 0.3rem;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        color: rgba(38, 24, 11, 0.62);
    }

    .instagram-link-external {
        font-size: 0.9rem;
        opacity: 0.62;
    }

    .f-col h5 {
        font-weight: 800;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        font-size: 1rem;
        letter-spacing: 1px;
        color: rgba(38, 24, 11, 0.9);
    }

    .f-list {
        list-style: none;
    }

    .f-list li {
        margin-bottom: 0.75rem;
    }

    .f-list li a {
        font-weight: 600;
        transition: opacity 0.3s ease;
        display: inline-block;
        padding: 0.25rem 0;
        color: rgba(38, 24, 11, 0.82);
    }

    .f-list li a:hover {
        opacity: 1;
        color: var(--brand-ink);
    }

    .f-list li a:focus-visible {
        box-shadow: var(--focus-ring-light);
        border-radius: 4px;
    }

    .f-list li span {
        font-weight: 700;
        font-size: 1rem;
        display: block;
    }

    .f-list li small {
        font-size: 0.8rem;
        color: rgba(38, 24, 11, 0.62);
        display: block;
        margin-top: 0.25rem;
    }

    .f-list li.active span {
        position: relative;
    }

    .f-list li.active span::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 100%;
        height: 2px;
        background: rgba(38, 24, 11, 0.7);
    }

    .sub-footer {
        padding: 1.5rem 0;
        text-align: center;
        font-size: 0.8rem;
        font-weight: 500;
        color: rgba(38, 24, 11, 0.72);
    }

    .sub-footer strong {
        font-weight: 700;
    }

    @media (max-width: 768px) {
        .footer-cta {
            padding: 3rem 0;
        }

        .cta-content {
            flex-direction: column;
            text-align: center;
            gap: 1.5rem;
        }

        .cta-content .btn-primary {
            width: 100%;
            justify-content: center;
        }

        .footer-grid {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 2.5rem;
        }

        .brand-col {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .instagram-link {
            justify-content: center;
        }

        .f-list li.active span::after {
            left: 50%;
            transform: translateX(-50%);
            width: 50%;
        }
    }
</style>
