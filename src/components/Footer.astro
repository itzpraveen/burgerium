---
import { instagramHandle, instagramUrl } from '../data/social';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname === '' ? '/' : Astro.url.pathname;
const isHomePage = currentPath === '/';
const currentYear = new Date().getFullYear();

const quickLinks = [
    { href: isHomePage ? '#about' : '/#about', label: 'Our Roots' },
    { href: isHomePage ? '#menu' : '/menu', label: 'Menu Highlights' },
    { href: isHomePage ? '#locations' : '/#locations', label: 'Locations' },
];

const socialLinks = [
    { href: instagramUrl, icon: 'fa-instagram', label: 'Follow us on Instagram' },
];
---

<footer role="contentinfo">
    <!-- Top Bar Call to Action -->
    <div class="footer-cta">
        <div class="container cta-content">
            <h3>Planning your first Burgerium visit?</h3>
            <a href={isHomePage ? '#locations' : '/#locations'} class="btn-primary">
                See Chennai House
                <i class="fas fa-arrow-right" aria-hidden="true"></i>
            </a>
        </div>
    </div>

    <!-- Main Footer -->
    <div class="main-footer">
        <div class="container">
            <div class="footer-grid">
                <!-- Brand Col -->
                <div class="f-col brand-col">
                    <img src={`${base}/logo.png`} alt="Burgerium" class="f-logo" loading="lazy" />
                    <p class="legal-line">A Unit of Urban Eats and Kitchen LLP</p>
                    <a
                        href={instagramUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="instagram-card"
                        aria-label={`Open Burgerium Instagram ${instagramHandle}`}
                    >
                        <span class="instagram-icon" aria-hidden="true">
                            <i class="fab fa-instagram"></i>
                        </span>
                        <span class="instagram-copy">
                            <strong>Instagram</strong>
                            <small>{instagramHandle}</small>
                        </span>
                        <i class="fas fa-arrow-up-right-from-square instagram-external" aria-hidden="true"></i>
                    </a>
                    <div class="socials" role="list" aria-label="Social media links">
                        {socialLinks.map((social) => (
                            <a
                                href={social.href}
                                target="_blank"
                                rel="noopener noreferrer"
                                aria-label={social.label}
                                role="listitem"
                            >
                                <i class={`fab ${social.icon}`} aria-hidden="true"></i>
                            </a>
                        ))}
                    </div>
                </div>

                <!-- Locations -->
                <div class="f-col">
                    <h5>Locations</h5>
                    <ul class="f-list" role="list">
                        <li class="active" role="listitem">
                            <span>Chennai</span>
                            <small>Nungambakkam</small>
                        </li>
                    </ul>
                </div>

                <!-- Links -->
                <nav class="f-col" aria-label="Footer navigation">
                    <h5>Quick Links</h5>
                    <ul class="f-list" role="list">
                        {quickLinks.map((link) => (
                            <li role="listitem">
                                <a href={link.href}>{link.label}</a>
                            </li>
                        ))}
                    </ul>
                </nav>
            </div>

            <div class="sub-footer">
                <p>&copy; {currentYear} Burgerium. <strong>A Unit of Urban Eats and Kitchen LLP</strong>.</p>
            </div>
        </div>
    </div>
</footer>

<style>
    /* CTA Bar */
    .footer-cta {
        background: linear-gradient(180deg, #fff1cb 0%, #ffd989 100%);
        padding: 3.6rem 0;
        border-top: 1px solid rgba(0, 0, 0, 0.06);
        border-bottom: 1px solid rgba(0,0,0,0.08);
    }

    .cta-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
    }

    .cta-content h3 {
        color: var(--text-white);
        font-size: clamp(1.6rem, 3vw, 2.3rem);
    }

    .cta-content .btn-primary {
        flex-shrink: 0;
    }

    /* Main Footer */
    .main-footer {
        background:
            radial-gradient(circle at top right, rgba(250, 162, 39, 0.12), transparent 22%),
            linear-gradient(180deg, #2b1d0d 0%, #160f08 100%);
        color: #fff5e5;
        padding-top: 4rem;
    }

    .footer-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr;
        gap: 3rem;
        padding-bottom: 3rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .f-logo {
        width: 180px;
        margin-bottom: 1.5rem;
    }

    .brand-col p {
        font-weight: 500;
        margin-bottom: 1rem;
        line-height: 1.6;
    }

    .legal-line {
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        color: rgba(255, 245, 229, 0.72);
        margin-bottom: 1.5rem;
    }

    .instagram-card {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 0.9rem;
        max-width: 320px;
        padding: 0.9rem 1rem;
        margin-bottom: 1rem;
        border: 1px solid rgba(255,255,255,0.14);
        background: rgba(255,248,233,0.08);
        color: #fff5e5;
        border-radius: 22px;
        transition: transform 0.25s ease, background 0.25s ease, border-color 0.25s ease;
    }

    .instagram-card:hover {
        transform: translateY(-2px);
        background: rgba(255,248,233,0.14);
        border-color: rgba(250,162,39,0.34);
    }

    .instagram-icon {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--brand-orange);
        color: #000;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
    }

    .instagram-copy {
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    .instagram-copy strong {
        font-family: var(--font-heading);
        font-size: 1.05rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        line-height: 1;
    }

    .instagram-copy small {
        margin-top: 0.3rem;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        color: rgba(255, 245, 229, 0.7);
    }

    .instagram-external {
        font-size: 0.9rem;
        opacity: 0.72;
    }

    .socials {
        display: flex;
        gap: 0.75rem;
    }

    .socials a {
        width: 40px;
        height: 40px;
        background: rgba(255, 248, 233, 0.08);
        color: #fff2d5;
        border: 1px solid rgba(255,255,255,0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: transform 0.3s ease, background 0.3s ease;
        font-size: 1rem;
    }

    .socials a:hover {
        transform: translateY(-3px);
        background: rgba(250, 162, 39, 0.18);
        color: var(--brand-orange);
    }

    .socials a:focus-visible {
        box-shadow: 0 0 0 3px rgba(250, 162, 39, 0.3);
    }

    .f-col h5 {
        font-weight: 800;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        font-size: 1rem;
        letter-spacing: 1px;
        color: var(--brand-orange);
    }

    .f-list {
        list-style: none;
    }

    .f-list li {
        margin-bottom: 0.75rem;
    }

    .f-list li a {
        font-weight: 600;
        transition: opacity 0.3s ease;
        display: inline-block;
        padding: 0.25rem 0;
    }

    .f-list li a:hover {
        opacity: 1;
        color: var(--brand-orange);
    }

    .f-list li a:focus-visible {
        box-shadow: var(--focus-ring-light);
        border-radius: 4px;
    }

    .f-list li span {
        font-weight: 700;
        font-size: 1rem;
        display: block;
    }

    .f-list li small {
        font-size: 0.8rem;
        color: rgba(255, 245, 229, 0.68);
        display: block;
        margin-top: 0.25rem;
    }

    .f-list li.active span {
        position: relative;
    }

    .f-list li.active span::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 100%;
        height: 2px;
        background: var(--brand-orange);
    }

    .sub-footer {
        padding: 1.5rem 0;
        text-align: center;
        font-size: 0.8rem;
        font-weight: 500;
        color: rgba(255, 245, 229, 0.74);
    }

    .sub-footer strong {
        font-weight: 700;
    }

    @media (max-width: 768px) {
        .footer-cta {
            padding: 3rem 0;
        }

        .cta-content {
            flex-direction: column;
            text-align: center;
            gap: 1.5rem;
        }

        .cta-content .btn-primary {
            width: 100%;
            justify-content: center;
        }

        .footer-grid {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 2.5rem;
        }

        .brand-col {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .instagram-card {
            width: 100%;
        }

        .socials {
            justify-content: center;
        }

        .f-list li.active span::after {
            left: 50%;
            transform: translateX(-50%);
            width: 50%;
        }
    }
</style>
