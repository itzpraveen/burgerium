---
import { menuItemCount, menuSectionCount, menuSections } from "../data/menu";

const formatPrice = (price: number) => `Rs ${price}`;
const getSectionCount = (section) =>
  section.blocks.reduce((total, block) => total + block.items.length, 0);
---

<section class="digital-menu-hero">
    <div class="container hero-shell">
    <div class="hero-copy scroll-reveal">
      <span class="hero-kicker">Burgerium Menu</span>
      <h1>The full house menu, laid out properly for the web.</h1>
      <p>
        Search by item, jump between sections, and get a feel for what you want before you arrive.
      </p>

      <div class="search-panel hero-search-panel">
        <label class="search-label" for="menu-search">Search the menu</label>
        <div class="search-field">
          <i class="fas fa-search" aria-hidden="true"></i>
          <input
            id="menu-search"
            data-menu-search
            type="search"
            placeholder="Search burgers, wraps, shakes, coffee..."
            autocomplete="off"
          />
          <button type="button" class="clear-search" data-clear-search hidden>
            Clear
          </button>
        </div>
        <p class="search-status" data-menu-status aria-live="polite">
          {menuItemCount} items across {menuSectionCount} sections.
        </p>
      </div>

      <div class="hero-actions">
        <a class="btn-primary" href="/#locations">See Chennai House</a>
        <a class="hero-link" href="/#about">Our Story</a>
      </div>
    </div>

    <div class="hero-notes scroll-reveal">
      <article class="hero-note">
        <strong>{menuItemCount}</strong>
        <span>items on the menu</span>
      </article>
      <article class="hero-note">
        <strong>{menuSectionCount}</strong>
        <span>sections to browse</span>
      </article>
      <article class="hero-note">
        <strong>Fresh Prep</strong>
        <span>Food is prepared once you order</span>
      </article>
      <article class="hero-note hero-note-wide">
        <strong>Prices shown before GST.</strong>
        <span>The kitchen works to order, so timings can vary during rush hours.</span>
      </article>
    </div>
  </div>
</section>

<section id="menu" class="digital-menu-directory" aria-labelledby="digital-menu-heading">
  <div class="container">
    <div class="directory-top scroll-reveal">
      <div>
        <span class="directory-kicker">Full Menu</span>
        <h2 id="digital-menu-heading">Pick a section and start browsing.</h2>
      </div>
      <p class="directory-note">
        Use the sticky rail below to move from burgers and fries to coffee, shakes, and desserts.
      </p>
    </div>

    <div class="section-rail scroll-reveal" aria-label="Menu sections">
      {menuSections.map((section) => (
        <a class="section-chip" data-menu-chip href={`#${section.slug}`}>
          {section.title}
        </a>
      ))}
    </div>

    <div class="catalog">
      {menuSections.map((section, sectionIndex) => (
        <section
          id={section.slug}
          class="catalog-section scroll-reveal"
          data-menu-section
          style={`--delay:${sectionIndex * 0.03}s`}
        >
          <div class="section-heading">
            <div>
              <span class="section-label">{section.label}</span>
              <h3>{section.title}</h3>
            </div>
            <p class="section-total">{getSectionCount(section)} items</p>
          </div>

          <div class={`section-blocks ${section.blocks.length === 1 ? "single-block" : ""}`}>
            {section.blocks.map((block) => (
              <article class="menu-block" data-menu-block>
                {(block.title || block.note) && (
                  <header class="block-head">
                    {block.title && <h4>{block.title}</h4>}
                    {block.note && <p>{block.note}</p>}
                  </header>
                )}

                <div class="item-list">
                  {block.items.map((item) => {
                    const searchValue = [
                      section.title,
                      section.label,
                      block.title,
                      block.note,
                      item.name,
                      item.description,
                    ]
                      .filter(Boolean)
                      .join(" ")
                      .toLowerCase();

                    return (
                      <article class="menu-item" data-menu-item data-search={searchValue}>
                        <div class="item-copy">
                          <div class="item-topline">
                            <h5>{item.name}</h5>
                            <span class="item-price">{formatPrice(item.price)}</span>
                          </div>
                          {item.description && <p>{item.description}</p>}
                        </div>
                      </article>
                    );
                  })}
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</section>

<script define:vars={{ menuItemCount, menuSectionCount }}>
  const searchInput = document.querySelector("[data-menu-search]");
  const clearSearchButton = document.querySelector("[data-clear-search]");
  const statusLabel = document.querySelector("[data-menu-status]");
  const menuSections = Array.from(document.querySelectorAll("[data-menu-section]"));

  const totalItems = menuItemCount;
  const totalSections = menuSectionCount;

  const updateMenuSearch = () => {
    const query = searchInput instanceof HTMLInputElement
      ? searchInput.value.trim().toLowerCase()
      : "";

    let visibleItems = 0;
    let visibleSections = 0;

    menuSections.forEach((section) => {
      const blocks = Array.from(section.querySelectorAll("[data-menu-block]"));
      let sectionHasMatch = false;

      blocks.forEach((block) => {
        const items = Array.from(block.querySelectorAll("[data-menu-item]"));
        let blockHasMatch = false;

        items.forEach((item) => {
          const matches = !query || item.dataset.search?.includes(query);
          item.hidden = !matches;

          if (matches) {
            visibleItems += 1;
            blockHasMatch = true;
            sectionHasMatch = true;
          }
        });

        block.hidden = !blockHasMatch;
      });

      section.hidden = !sectionHasMatch;

      if (sectionHasMatch) {
        visibleSections += 1;
      }
    });

    if (clearSearchButton instanceof HTMLButtonElement) {
      clearSearchButton.hidden = !query;
    }

    if (statusLabel instanceof HTMLElement) {
      if (query) {
        const label = searchInput instanceof HTMLInputElement ? searchInput.value.trim() : "";
        statusLabel.textContent = `${visibleItems} items match "${label}" across ${visibleSections} sections.`;
      } else {
        statusLabel.textContent = `${totalItems} items across ${totalSections} sections.`;
      }
    }
  };

  if (searchInput instanceof HTMLInputElement) {
    searchInput.addEventListener("input", updateMenuSearch);
  }

  if (clearSearchButton instanceof HTMLButtonElement && searchInput instanceof HTMLInputElement) {
    clearSearchButton.addEventListener("click", () => {
      searchInput.value = "";
      updateMenuSearch();
      searchInput.focus();
    });
  }

  updateMenuSearch();
</script>

<style>
  .digital-menu-hero {
    padding: calc(var(--header-height) + 3.6rem) 0 2.8rem;
    background:
      radial-gradient(circle at top right, rgba(250, 162, 39, 0.16), transparent 30%),
      radial-gradient(circle at left center, rgba(250, 162, 39, 0.08), transparent 28%),
      linear-gradient(180deg, #fff8eb 0%, #ffe4a8 100%);
    border-bottom: 1px solid rgba(75, 47, 10, 0.08);
  }

  .hero-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: 1.75rem;
    align-items: end;
  }

  .hero-copy {
    padding: 1.7rem;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-lg);
    background: rgba(255, 250, 241, 0.74);
    box-shadow: var(--shadow-soft);
  }

  .hero-kicker,
  .directory-kicker,
  .section-label {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0.34rem 0.85rem;
    border-radius: 999px;
    background: rgba(250, 162, 39, 0.14);
    color: var(--brand-orange);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero-copy h1 {
    margin: 1rem 0 0.9rem;
    max-width: 12ch;
    font-size: clamp(2.9rem, 6vw, 5.1rem);
    line-height: 0.92;
  }

  .hero-copy p {
    max-width: 58ch;
    color: var(--text-gray);
    font-size: 1.04rem;
    line-height: 1.72;
  }

  .hero-search-panel {
    margin-top: 1.4rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.25rem;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 58px;
    padding: 1rem 1.5rem;
    border: 1px solid var(--line-strong);
    color: var(--text-white);
    font-family: var(--font-heading);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-radius: 18px;
    background: rgba(255, 251, 244, 0.6);
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease;
  }

  .hero-link:hover {
    transform: translateY(-2px);
    border-color: var(--brand-orange);
    background: rgba(250, 162, 39, 0.08);
  }

  .hero-notes {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .hero-note {
    min-height: 132px;
    padding: 1rem;
    border: 1px solid var(--line-soft);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(255, 255, 255, 0.36)),
      linear-gradient(150deg, rgba(250, 162, 39, 0.16), transparent 55%);
    box-shadow: 0 12px 24px rgba(75, 47, 10, 0.05);
  }

  .hero-note strong {
    display: block;
    margin-bottom: 0.35rem;
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3vw, 2.8rem);
    line-height: 0.95;
    color: var(--text-white);
  }

  .hero-note span {
    display: block;
    color: var(--text-gray);
    line-height: 1.5;
  }

  .hero-note-wide {
    grid-column: span 2;
    min-height: 0;
  }

  .digital-menu-directory {
    padding: 1rem 0 6rem;
    background:
      linear-gradient(180deg, #fff7e0 0%, #fff0cd 100%);
  }

  .directory-top {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.7fr);
    gap: 1.2rem;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .directory-top h2 {
    margin-top: 1rem;
    max-width: 14ch;
    font-size: clamp(2.2rem, 4.5vw, 3.7rem);
    line-height: 0.95;
  }

  .directory-note {
    max-width: 31ch;
    margin-left: auto;
    color: var(--text-gray);
    line-height: 1.7;
  }

  .search-panel {
    padding: 1.1rem;
    border: 1px solid var(--line-soft);
    background: rgba(255, 249, 237, 0.88);
    border-radius: 26px;
    box-shadow: 0 12px 24px rgba(75, 47, 10, 0.05);
  }

  .search-label {
    display: block;
    margin-bottom: 0.7rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-gray);
  }

  .search-field {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.75rem;
    align-items: center;
    min-height: 60px;
    padding: 0 1rem;
    border: 1px solid var(--line-soft);
    background: rgba(255, 255, 255, 0.5);
    border-radius: 18px;
  }

  .search-field i {
    color: var(--brand-orange);
  }

  .search-field input {
    width: 100%;
    border: 0;
    background: transparent;
    color: var(--text-white);
    font: inherit;
    min-height: 58px;
  }

  .search-field input::placeholder {
    color: var(--text-muted);
  }

  .search-field input:focus {
    outline: none;
  }

  .clear-search {
    border: 0;
    background: rgba(250, 162, 39, 0.16);
    color: var(--brand-orange-deep);
    padding: 0.5rem 0.8rem;
    font-weight: 700;
    cursor: pointer;
    border-radius: 999px;
  }

  .search-status {
    margin-top: 0.65rem;
    color: var(--text-gray);
    line-height: 1.5;
  }

  .section-rail {
    position: sticky;
    top: calc(var(--header-height) + 0.8rem);
    z-index: 40;
    display: flex;
    gap: 0.7rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    padding: 0.7rem;
    border: 1px solid var(--line-soft);
    background: rgba(255, 248, 232, 0.86);
    backdrop-filter: blur(16px);
    scroll-snap-type: x proximity;
    border-radius: 24px;
    box-shadow: 0 12px 20px rgba(75, 47, 10, 0.04);
  }

  .section-chip {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    min-height: 42px;
    padding: 0.5rem 0.95rem;
    border: 1px solid var(--line-soft);
    color: var(--text-white);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: border-color 0.25s ease, transform 0.25s ease, background 0.25s ease;
    scroll-snap-align: start;
  }

  .section-chip:hover {
    transform: translateY(-2px);
    border-color: var(--brand-orange);
    background: rgba(250, 162, 39, 0.08);
  }

  .catalog {
    display: grid;
    gap: 1.25rem;
  }

  .catalog-section {
    padding: 1.3rem;
    border: 1px solid var(--line-soft);
    border-radius: 28px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(255, 255, 255, 0.34)),
      linear-gradient(160deg, rgba(250, 162, 39, 0.12), transparent 45%);
    transition: border-color 0.3s ease, transform 0.3s ease;
    transition-delay: var(--delay, 0s);
  }

  .catalog-section:hover {
    border-color: rgba(250, 162, 39, 0.35);
  }

  .section-heading {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1rem;
  }

  .section-heading h3 {
    margin-top: 0.9rem;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 0.95;
  }

  .section-total {
    color: var(--text-gray);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.82rem;
    white-space: nowrap;
  }

  .section-blocks {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  .section-blocks.single-block {
    grid-template-columns: 1fr;
  }

  .menu-block {
    padding: 1rem;
    border: 1px solid var(--line-soft);
    background: rgba(255, 250, 240, 0.86);
    border-radius: 22px;
  }

  .block-head {
    margin-bottom: 1rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--line-soft);
  }

  .block-head h4 {
    font-size: 1.2rem;
    margin-bottom: 0.45rem;
  }

  .block-head p {
    color: var(--text-gray);
    line-height: 1.65;
    font-size: 0.94rem;
  }

  .item-list {
    display: grid;
    gap: 0.85rem;
  }

  .menu-item {
    padding-bottom: 0.85rem;
    border-bottom: 1px solid rgba(71, 45, 6, 0.08);
  }

  .menu-item:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .item-topline {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: start;
    margin-bottom: 0.35rem;
  }

  .item-topline h5 {
    font-family: var(--font-body);
    font-size: 1.03rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: none;
    line-height: 1.4;
  }

  .item-price {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0.2rem 0.75rem;
    border-radius: 999px;
    background: rgba(250, 162, 39, 0.14);
    color: var(--brand-orange-deep);
    font-weight: 700;
    font-size: 0.82rem;
  }

  .item-copy p {
    color: var(--text-gray);
    line-height: 1.65;
    font-size: 0.94rem;
  }

  @media (max-width: 980px) {
    .hero-shell,
    .directory-top {
      grid-template-columns: 1fr;
    }

    .hero-copy h1,
    .directory-top h2 {
      max-width: none;
    }

    .section-rail {
      top: calc(var(--header-height) + 0.5rem);
    }

    .directory-note {
      margin-left: 0;
      max-width: none;
    }
  }

  @media (max-width: 720px) {
    .digital-menu-hero {
      padding: calc(var(--header-height) + 2.5rem) 0 2rem;
    }

    .hero-shell {
      gap: 1rem;
    }

    .hero-copy {
      padding: 1.2rem;
      border-radius: 26px;
    }

    .hero-copy h1 {
      font-size: clamp(2.5rem, 12vw, 3.4rem);
      line-height: 0.94;
      margin: 0.85rem 0;
    }

    .hero-copy p {
      font-size: 0.98rem;
      line-height: 1.7;
    }

    .hero-notes {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.7rem;
    }

    .hero-note-wide {
      grid-column: span 2;
    }

    .hero-actions {
      flex-direction: column;
    }

    .hero-actions :global(.btn-primary),
    .hero-link {
      width: 100%;
      justify-content: center;
    }

    .directory-top {
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .search-panel {
      padding: 0.9rem;
      border-radius: 22px;
    }

    .search-field {
      min-height: 56px;
      padding: 0 0.8rem;
      gap: 0.55rem;
    }

    .search-field input {
      min-height: 54px;
      font-size: 0.98rem;
    }

    .section-rail {
      margin-bottom: 1rem;
      padding: 0.55rem;
      border-radius: 18px;
      scrollbar-width: none;
    }

    .section-rail::-webkit-scrollbar {
      display: none;
    }

    .section-chip {
      min-height: 38px;
      padding: 0.45rem 0.8rem;
      font-size: 0.78rem;
    }

    .section-heading,
    .item-topline {
      flex-direction: column;
      align-items: start;
    }

    .catalog-section,
    .menu-block,
    .search-panel {
      padding: 1rem;
    }

    .catalog-section {
      border-radius: 24px;
    }

    .menu-block {
      border-radius: 18px;
    }

    .section-heading h3 {
      font-size: clamp(1.7rem, 8vw, 2.2rem);
    }

    .section-total {
      white-space: normal;
    }

    .item-topline {
      gap: 0.5rem;
    }

    .item-price {
      min-height: 30px;
      padding: 0.2rem 0.62rem;
      font-size: 0.76rem;
    }
  }

  @media (max-width: 520px) {
    .hero-note {
      min-height: 112px;
      padding: 0.85rem;
    }

    .hero-note strong {
      font-size: 1.7rem;
    }

    .hero-notes {
      grid-template-columns: 1fr;
    }

    .hero-note-wide {
      grid-column: auto;
    }

    .search-status {
      font-size: 0.9rem;
    }
  }
</style>
