---
import {
  menuSections,
  type MenuBlock,
  type MenuItem,
  type MenuSection,
} from "../data/menu";

interface MenuGroupDefinition {
  slug: string;
  kicker: string;
  title: string;
  summary: string;
  sectionSlugs: string[];
}

interface MenuGroup extends MenuGroupDefinition {
  sections: MenuSection[];
  itemCount: number;
  sectionCount: number;
  startingPrice: number;
  previewItems: string[];
}

interface SignatureDefinition {
  sectionSlug: string;
  itemName: string;
  badge: string;
  note: string;
}

interface QuickFilterDefinition {
  id: string;
  label: string;
}

interface CardMeta {
  searchValue: string;
  shortDescription: string;
  tags: string[];
  tagIds: string[];
}

interface PreparedSignature extends CardMeta {
  badge: string;
  note: string;
  group: MenuGroup;
  section: MenuSection;
  block: MenuBlock;
  item: MenuItem;
}

const pdfMenuPath = "/Burgerium-Menu.pdf";
const defaultStatus = "Browse favourites or use a quick filter.";

const formatPrice = (price: number) => `Rs ${price}`;
const normalize = (value?: string) => value?.toLowerCase() ?? "";
const buildSearchValue = (values: Array<string | undefined>) =>
  values.filter(Boolean).join(" ").toLowerCase();
const shortenCopy = (value?: string, maxLength = 108) => {
  if (!value) {
    return "";
  }

  return value.length <= maxLength
    ? value
    : `${value.slice(0, maxLength - 3).trimEnd()}...`;
};

const filterIdForTag = (value: string) =>
  value.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");

const hasAnyKeyword = (text: string, keywords: string[]) =>
  keywords.some((keyword) => text.includes(keyword));

const getItems = (section: MenuSection) =>
  section.blocks.flatMap((block) => block.items);

const getStartingPrice = (section: MenuSection) =>
  Math.min(...getItems(section).map((item) => item.price));

const getPreviewItems = (section: MenuSection) =>
  getItems(section)
    .slice(0, 3)
    .map((item) => item.name)
    .join(" • ");

const findSections = (slugs: string[]) =>
  slugs
    .map((slug) => menuSections.find((section) => section.slug === slug))
    .filter((section): section is MenuSection => Boolean(section));

const menuGroupDefinitions: MenuGroupDefinition[] = [
  {
    slug: "burgers",
    kicker: "Most ordered",
    title: "Burgers",
    summary: "Chicken, beef, signature stacks, veg burgers, and kids picks in one place.",
    sectionSlugs: [
      "classic-chicken-burgers",
      "beef-burgers",
      "signature-burgers",
      "veg-burgers",
      "sliders-kids",
    ],
  },
  {
    slug: "wraps-bowls",
    kicker: "Handhelds",
    title: "Wraps, subs & bowls",
    summary: "For guests who want the same Burgerium flavours in wraps, subs, and bowl format.",
    sectionSlugs: [
      "subwiches",
      "rolls-wraps",
      "burger-bowls",
      "veg-subwiches-bowls-salads",
    ],
  },
  {
    slug: "sides-salads",
    kicker: "Add something",
    title: "Fries, strips & salads",
    summary: "Loaded fries, tenders, grilled plates, and salads to round out the table.",
    sectionSlugs: [
      "fries-starters",
      "grilled-non-veg-salads",
      "strips-tenders",
    ],
  },
  {
    slug: "cold-drinks-desserts",
    kicker: "Sweet and cold",
    title: "Shakes, coolers & desserts",
    summary: "Milkshakes, mojitos, desserts, faloodas, and iced coffee for the second half of the meal.",
    sectionSlugs: [
      "milkshakes",
      "mojitos",
      "iced-treats-desserts",
      "iced-coffee",
    ],
  },
  {
    slug: "coffee-tea",
    kicker: "Cafe side",
    title: "Coffee & tea",
    summary: "Hot coffees, espresso drinks, tea infusions, and slower cafe sips.",
    sectionSlugs: ["hot-coffee-tea", "hot-coffee"],
  },
];

const quickFilters: QuickFilterDefinition[] = [
  { id: "all", label: "All" },
  { id: "veg", label: "Veg" },
  { id: "non-veg", label: "Non-Veg" },
  { id: "spicy", label: "Spicy" },
  { id: "bestseller", label: "Bestsellers" },
  { id: "under-rs-300", label: "Under Rs 300" },
  { id: "coffee", label: "Coffee" },
  { id: "dessert", label: "Dessert" },
];

const signatureDefinitions: SignatureDefinition[] = [
  {
    sectionSlug: "signature-burgers",
    itemName: "Brooklyn Chick",
    badge: "Signature stack",
    note: "A stacked chicken burger with fries, fresh veggies, and cheesy cream.",
  },
  {
    sectionSlug: "beef-burgers",
    itemName: "Smash Buff",
    badge: "Fast favourite",
    note: "A straightforward beef burger with a rich, satisfying finish.",
  },
  {
    sectionSlug: "classic-chicken-burgers",
    itemName: "Sweet Fire Zing",
    badge: "Crispy classic",
    note: "Crispy chicken with sweet heat and plenty of crunch.",
  },
  {
    sectionSlug: "veg-burgers",
    itemName: "Red Flame Paneer",
    badge: "Veg standout",
    note: "A bold paneer burger with spicy, cheesy flavour.",
  },
  {
    sectionSlug: "burger-bowls",
    itemName: "Crunchy Buff Bowl",
    badge: "No-bun route",
    note: "All the Burgerium flavour in a bowl without the bun.",
  },
  {
    sectionSlug: "milkshakes",
    itemName: "Biscoff Blitz",
    badge: "Sweet finish",
    note: "A creamy Biscoff shake for a sweet finish.",
  },
];

const heroPromises = [
  "Veg and non-veg are clearly marked.",
  "Prices stay visible before you open each section.",
  "Download the PDF if you want the full menu in one view.",
];

const menuGroups: MenuGroup[] = menuGroupDefinitions
  .map((group) => {
    const sections = findSections(group.sectionSlugs);
    const items = sections.flatMap((section) => getItems(section));

    return {
      ...group,
      sections,
      itemCount: items.length,
      sectionCount: sections.length,
      startingPrice: Math.min(...items.map((item) => item.price)),
      previewItems: items.slice(0, 3).map((item) => item.name),
    };
  })
  .filter((group) => group.sections.length > 0);

const signatureNameIds = new Set(
  signatureDefinitions.map((signature) => normalize(signature.itemName)),
);

const getGroupForSection = (sectionSlug: string) =>
  menuGroups.find((group) =>
    group.sections.some((section) => section.slug === sectionSlug),
  );

const inferTags = (
  group: MenuGroup,
  section: MenuSection,
  block: MenuBlock,
  item: MenuItem,
) => {
  const text = buildSearchValue([
    group.title,
    group.summary,
    section.title,
    section.label,
    block.title,
    block.note,
    item.name,
    item.description,
  ]);
  const itemText = buildSearchValue([
    block.title,
    block.note,
    item.name,
    item.description,
  ]);

  const tags = new Set<string>();
  const sectionLabel = normalize(section.label);
  const sectionTitle = normalize(section.title);

  if (
    sectionLabel.includes("vegetarian") ||
    sectionTitle.includes("veg") ||
    text.includes("paneer") ||
    text.includes("shroom")
  ) {
    tags.add("Veg");
  } else if (
    sectionLabel.includes("non-veg") ||
    sectionLabel.includes("chef") ||
    text.includes("chicken") ||
    text.includes("beef") ||
    text.includes("buff")
  ) {
    tags.add("Non-Veg");
  }

  if (
    hasAnyKeyword(text, [
      "spicy",
      "peri peri",
      "peri-peri",
      "chilli",
      "chili",
      "nashville",
      "dragon",
      "flame",
      "fiery",
      "schezwan",
      "zing",
      "sizzling",
    ])
  ) {
    tags.add("Spicy");
  }

  if (item.price <= 299) {
    tags.add("Under Rs 300");
  }

  if (signatureNameIds.has(normalize(item.name))) {
    tags.add("Bestseller");
  }

  if (
    hasAnyKeyword(itemText, [
      "latte",
      "espresso",
      "americano",
      "cappuccino",
      "affogato",
      "mocha",
      "mochachino",
      "coffee",
      "hot chocolate",
      "machiatto",
    ])
  ) {
    tags.add("Coffee");
  }

  const dessertText = buildSearchValue([
    block.title,
    block.note,
    item.name,
    item.description,
  ]);

  if (
    group.slug === "cold-drinks-desserts" &&
    hasAnyKeyword(dessertText, [
      "dessert",
      "sundae",
      "falooda",
      "brownie",
      "ice cream",
    ])
  ) {
    tags.add("Dessert");
  }

  return Array.from(tags);
};

const buildCardMeta = (
  group: MenuGroup,
  section: MenuSection,
  block: MenuBlock,
  item: MenuItem,
): CardMeta => {
  const tags = inferTags(group, section, block, item);

  return {
    searchValue: buildSearchValue([
      group.title,
      group.summary,
      section.title,
      section.label,
      block.title,
      block.note,
      item.name,
      item.description,
      ...tags,
    ]),
    shortDescription: shortenCopy(item.description),
    tags,
    tagIds: tags.map(filterIdForTag),
  };
};

const createSignatureItem = (
  definition: SignatureDefinition,
): PreparedSignature | null => {
  const group = getGroupForSection(definition.sectionSlug);

  if (!group) {
    return null;
  }

  const section = group.sections.find(
    (currentSection) => currentSection.slug === definition.sectionSlug,
  );

  if (!section) {
    return null;
  }

  const block = section.blocks.find((currentBlock) =>
    currentBlock.items.some((item) => item.name === definition.itemName),
  );

  const item = block?.items.find(
    (currentItem) => currentItem.name === definition.itemName,
  );

  if (!block || !item) {
    return null;
  }

  return {
    ...buildCardMeta(group, section, block, item),
    ...definition,
    group,
    section,
    block,
    item,
  };
};

const signatureItems = signatureDefinitions
  .map(createSignatureItem)
  .filter((signature): signature is PreparedSignature => Boolean(signature));

const heroSpotlights = signatureItems.slice(0, 4);
---

<section class="menu-hero">
  <div class="container hero-layout">
    <div class="hero-copy scroll-reveal">
      <span class="eyebrow">Burgerium menu</span>
      <h1>What are you craving today?</h1>
      <p class="hero-lead">
        Start with a category, explore a few favourites, or open the full PDF if you want the whole menu at
        once.
      </p>

      <div class="craving-row" aria-label="Menu categories">
        {menuGroups.map((group) => (
          <a href={`#${group.slug}`} class="craving-chip">
            <span>{group.kicker}</span>
            <strong>{group.title}</strong>
          </a>
        ))}
      </div>

      <div class="hero-actions">
        <a class="btn-primary" href="#signatures">See signatures</a>
        <a class="btn-secondary menu-pdf-link" href={pdfMenuPath} target="_blank" rel="noopener noreferrer">
          Download PDF
          <i class="fas fa-arrow-up-right-from-square" aria-hidden="true"></i>
        </a>
      </div>

      <a class="pdf-feature scroll-reveal" href={pdfMenuPath} target="_blank" rel="noopener noreferrer">
        <div class="pdf-feature-copy">
          <span class="eyebrow pdf-eyebrow">Want the full menu?</span>
          <strong>Open the full PDF menu</strong>
          <p>See every page of the Burgerium menu in one PDF.</p>
        </div>
        <span class="pdf-feature-link">
          View PDF
          <i class="fas fa-arrow-up-right-from-square" aria-hidden="true"></i>
        </span>
      </a>

      <div class="promise-row">
        {heroPromises.map((promise) => (
          <span class="promise-pill">{promise}</span>
        ))}
      </div>
    </div>

    <aside class="hero-spotlight scroll-reveal" aria-labelledby="hero-spotlight-heading">
      <div class="panel-head">
        <span class="eyebrow">Fast picks</span>
        <h2 id="hero-spotlight-heading">Popular picks to start with.</h2>
      </div>

      <div class="spotlight-grid">
        {heroSpotlights.map((signature) => (
          <article class="spotlight-card">
            <div class="spotlight-top">
              <span class="spotlight-badge">{signature.badge}</span>
              <span class="spotlight-price">{formatPrice(signature.item.price)}</span>
            </div>
            <h3>{signature.item.name}</h3>
            <p>{signature.note}</p>
            <div class="spotlight-bottom">
              <span>{signature.section.title}</span>
              <a href={`#${signature.group.slug}`}>Open</a>
            </div>
          </article>
        ))}
      </div>
    </aside>
  </div>
</section>

<section id="signatures" class="signature-rack" aria-labelledby="signatures-heading">
  <div class="container">
    <div class="section-top scroll-reveal">
      <div>
        <span class="eyebrow">Burgerium signatures</span>
        <h2 id="signatures-heading">Guest favourites.</h2>
      </div>
      <p>A few guest favourites from across the menu.</p>
    </div>

    <div class="signature-grid">
      {signatureItems.map((signature, index) => (
        <article
          class="signature-card scroll-reveal"
          style={`--delay:${index * 0.04}s`}
          data-signature-card
          data-tags={signature.tagIds.join(" ")}
          data-search={signature.searchValue}
        >
          <div class="signature-top">
            <div>
              <span class="eyebrow signature-eyebrow">{signature.badge}</span>
              <h3>{signature.item.name}</h3>
            </div>
            <span class="signature-price">{formatPrice(signature.item.price)}</span>
          </div>

          <p class="signature-note">{signature.note}</p>
          {signature.shortDescription && <p class="signature-copy">{signature.shortDescription}</p>}

          <div class="tag-row">
            {signature.tags.slice(0, 3).map((tag) => (
              <span class="item-tag">{tag}</span>
            ))}
          </div>

          <div class="signature-bottom">
            <span>{signature.section.title}</span>
            <a href={`#${signature.group.slug}`}>Open in menu</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="menu-explorer" aria-labelledby="menu-explorer-heading">
  <div class="container">
    <div class="section-top explorer-top scroll-reveal">
      <div>
        <span class="eyebrow">Full menu</span>
        <h2 id="menu-explorer-heading">Browse the full menu.</h2>
      </div>
      <p>Search by item, use a quick filter, or jump straight to a category.</p>
    </div>

    <div class="toolbar-shell scroll-reveal">
      <div class="search-panel">
        <label class="search-label" for="menu-search">Search the menu</label>
        <div class="search-field">
          <i class="fas fa-search" aria-hidden="true"></i>
          <input
            id="menu-search"
            data-menu-search
            type="search"
            placeholder="Search burgers, wraps, coffee, dessert..."
            autocomplete="off"
          />
          <button type="button" class="clear-search" data-clear-search hidden>
            Clear
          </button>
        </div>
      </div>

      <div class="filter-bar" role="toolbar" aria-label="Quick menu filters">
        {quickFilters.map((filter, index) => (
          <button
            type="button"
            class={`filter-chip ${index === 0 ? "is-active" : ""}`}
            data-menu-filter={filter.id}
            aria-pressed={index === 0 ? "true" : "false"}
          >
            {filter.label}
          </button>
        ))}
      </div>

      <p class="toolbar-status" data-menu-status aria-live="polite">{defaultStatus}</p>
    </div>

    <nav class="category-rail scroll-reveal" aria-label="Menu group navigation">
      {menuGroups.map((group) => (
        <a href={`#${group.slug}`} class="category-link" data-group-link data-group-target={group.slug}>
          <span>{group.kicker}</span>
          <strong>{group.title}</strong>
          <small>From {formatPrice(group.startingPrice)}</small>
        </a>
      ))}
    </nav>

    <div class="group-stack">
      {menuGroups.map((group, groupIndex) => (
        <section
          id={group.slug}
          class="menu-group scroll-reveal"
          data-menu-group
          style={`--delay:${groupIndex * 0.05}s`}
        >
          <div class="menu-group-head">
            <div>
              <span class="eyebrow group-eyebrow">{group.kicker}</span>
              <h3>{group.title}</h3>
              <p>{group.summary}</p>
              <div class="preview-row">
                {group.previewItems.map((itemName) => (
                  <span class="preview-pill">{itemName}</span>
                ))}
              </div>
            </div>

            <div class="group-summary">
              <span>From {formatPrice(group.startingPrice)}</span>
              <span>{group.sectionCount} sections</span>
              <span>{group.itemCount} items</span>
            </div>
          </div>

          <div class="section-list">
            {group.sections.map((section, sectionIndex) => {
              const isDefaultOpen = groupIndex === 0 && sectionIndex === 0;
              const sectionNote =
                section.blocks.find((block) => block.note)?.note ??
                section.blocks.find((block) => block.title)?.title ??
                "";

              return (
                <details
                  class="section-panel"
                  data-menu-section
                  data-default-open={isDefaultOpen ? "true" : "false"}
                  open={isDefaultOpen}
                >
                  <summary class="section-summary">
                    <div class="section-copy">
                      <div class="section-topline">
                        <span class="section-label">{section.label}</span>
                        <span class="section-price">From {formatPrice(getStartingPrice(section))}</span>
                      </div>
                      <h4>{section.title}</h4>
                      <p>{sectionNote || getPreviewItems(section)}</p>
                    </div>

                    <span class="section-toggle">
                      <span class="show-label">Open</span>
                      <span class="hide-label">Close</span>
                      <i class="fas fa-arrow-right" aria-hidden="true"></i>
                    </span>
                  </summary>

                  <div class="section-body">
                    {section.blocks.map((block: MenuBlock) => (
                      <article class="item-cluster" data-menu-block>
                        {(block.title || block.note) && (
                          <header class="cluster-head">
                            {block.title && <h5>{block.title}</h5>}
                            {block.note && <p>{block.note}</p>}
                          </header>
                        )}

                        <div class="item-grid">
                          {block.items.map((item: MenuItem) => {
                            const meta = buildCardMeta(group, section, block, item);

                            return (
                              <article
                                class="menu-item-card"
                                data-menu-item
                                data-tags={meta.tagIds.join(" ")}
                                data-search={meta.searchValue}
                              >
                                <div class="menu-item-head">
                                  <div>
                                    <h6>{item.name}</h6>
                                    <div class="tag-row">
                                      {meta.tags.slice(0, 4).map((tag) => (
                                        <span class="item-tag">{tag}</span>
                                      ))}
                                    </div>
                                  </div>
                                  <span class="item-price">{formatPrice(item.price)}</span>
                                </div>
                                {meta.shortDescription && <p>{meta.shortDescription}</p>}
                              </article>
                            );
                          })}
                        </div>
                      </article>
                    ))}
                  </div>
                </details>
              );
            })}
          </div>
        </section>
      ))}
    </div>
  </div>
</section>

<script define:vars={{ defaultStatus }}>
  const searchInput = document.querySelector("[data-menu-search]");
  const clearSearchButton = document.querySelector("[data-clear-search]");
  const statusLabel = document.querySelector("[data-menu-status]");
  const filterButtons = Array.from(document.querySelectorAll("[data-menu-filter]"));
  const groupPanels = Array.from(document.querySelectorAll("[data-menu-group]"));
  const groupLinks = Array.from(document.querySelectorAll("[data-group-link]"));
  const signatureCards = Array.from(document.querySelectorAll("[data-signature-card]"));

  let activeFilter = "all";

  const setActiveFilter = (nextFilter) => {
    activeFilter = nextFilter;

    filterButtons.forEach((button) => {
      const isActive = button.dataset.menuFilter === nextFilter;
      button.classList.toggle("is-active", isActive);
      button.setAttribute("aria-pressed", String(isActive));
    });
  };

  const itemMatchesFilter = (item, filterId) => {
    if (filterId === "all") {
      return true;
    }

    const tags = item.dataset.tags?.split(" ").filter(Boolean) ?? [];
    return tags.includes(filterId);
  };

  const updateMenuView = () => {
    const query = searchInput instanceof HTMLInputElement
      ? searchInput.value.trim().toLowerCase()
      : "";

    let visibleItems = 0;
    let visibleSections = 0;
    let visibleGroups = 0;
    let visibleSignatures = 0;

    groupPanels.forEach((groupPanel) => {
      const sections = Array.from(groupPanel.querySelectorAll("[data-menu-section]"));
      let groupHasMatch = false;

      sections.forEach((section) => {
        const blocks = Array.from(section.querySelectorAll("[data-menu-block]"));
        let sectionHasMatch = false;

        blocks.forEach((block) => {
          const items = Array.from(block.querySelectorAll("[data-menu-item]"));
          let blockHasMatch = false;

          items.forEach((item) => {
            const matchesQuery = !query || item.dataset.search?.includes(query);
            const matchesFilter = itemMatchesFilter(item, activeFilter);
            const matches = matchesQuery && matchesFilter;

            item.hidden = !matches;

            if (matches) {
              visibleItems += 1;
              blockHasMatch = true;
              sectionHasMatch = true;
            }
          });

          block.hidden = !blockHasMatch;
        });

        section.hidden = !sectionHasMatch;

        if (section instanceof HTMLDetailsElement) {
          if (query || activeFilter !== "all") {
            section.open = sectionHasMatch;
          } else {
            section.open = section.dataset.defaultOpen === "true";
          }
        }

        if (sectionHasMatch) {
          visibleSections += 1;
          groupHasMatch = true;
        }
      });

      groupPanel.hidden = !groupHasMatch;

      if (groupHasMatch) {
        visibleGroups += 1;
      }
    });

    groupLinks.forEach((link) => {
      const target = link.dataset.groupTarget;
      const targetPanel = target
        ? document.getElementById(target)
        : null;
      link.hidden = Boolean(targetPanel?.hidden);
    });

    signatureCards.forEach((card) => {
      const matchesQuery = !query || card.dataset.search?.includes(query);
      const matchesFilter = itemMatchesFilter(card, activeFilter);
      const matches = matchesQuery && matchesFilter;

      card.hidden = !matches;

      if (matches) {
        visibleSignatures += 1;
      }
    });

    if (clearSearchButton instanceof HTMLButtonElement) {
      clearSearchButton.hidden = !query;
    }

    if (statusLabel instanceof HTMLElement) {
      if (!query && activeFilter === "all") {
        statusLabel.textContent = defaultStatus;
      } else if (visibleItems === 0) {
        statusLabel.textContent = "No menu items match this view. Try another filter or search term.";
      } else {
        const filterLabel = activeFilter === "all"
          ? "all items"
          : activeFilter.replace(/-/g, " ");
        const signatureCopy = visibleSignatures > 0
          ? ` ${visibleSignatures} signature pick${visibleSignatures === 1 ? "" : "s"} still fit too.`
          : "";

        const groupLabel = visibleGroups === 1 ? "category" : "categories";
        statusLabel.textContent =
          `Showing ${visibleItems} item${visibleItems === 1 ? "" : "s"} across ${visibleSections} section${visibleSections === 1 ? "" : "s"} in ${visibleGroups} ${groupLabel} for ${filterLabel}.${signatureCopy}`;
      }
    }
  };

  if (searchInput instanceof HTMLInputElement) {
    searchInput.addEventListener("input", updateMenuView);
  }

  if (clearSearchButton instanceof HTMLButtonElement && searchInput instanceof HTMLInputElement) {
    clearSearchButton.addEventListener("click", () => {
      searchInput.value = "";
      updateMenuView();
      searchInput.focus();
    });
  }

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const nextFilter = button.dataset.menuFilter ?? "all";
      setActiveFilter(nextFilter);
      updateMenuView();
    });
  });

  setActiveFilter("all");
  updateMenuView();
</script>

