---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Anatomy from '../components/Anatomy.astro';
import Menu from '../components/Menu.astro';
import Craft from '../components/Craft.astro';
import Reviews from '../components/Reviews.astro';
import Locations from '../components/Locations.astro';
import Footer from '../components/Footer.astro';

const marqueeItems = [
    'Burgerium',
    'Bakery roots since 1998',
    'From the Burger Tree family',
    'Nungambakkam, Chennai',
    'See menu and prices before you visit',
    'Opening updates land on Instagram first'
];

const getMarqueeItemClass = (index: number) =>
    index % 2 === 0 ? 'marquee-item is-solid' : 'marquee-item is-tag';
---

<Layout
    title="Burgerium | Nungambakkam, Chennai Burger House"
    description="Burgerium is opening in Nungambakkam, Chennai (E Merck House, Haddows 2nd Street, 600006). House-baked buns and flame-grilled burgers."
>
    <Navigation />
    <div class="page">
        <Hero />

        <div class="marquee-container" aria-label="Burgerium signature traits">
            <div class="marquee-track">
                <div class="marquee-group">
                    {marqueeItems.map((item, index) => (
                        <>
                            <span class={getMarqueeItemClass(index)}>{item}</span>
                            {index < marqueeItems.length - 1 && <span class="separator" aria-hidden="true">•</span>}
                        </>
                    ))}
                </div>
                <div class="marquee-group" aria-hidden="true">
                    {marqueeItems.map((item, index) => (
                        <>
                            <span class={getMarqueeItemClass(index)}>{item}</span>
                            {index < marqueeItems.length - 1 && <span class="separator" aria-hidden="true">•</span>}
                        </>
                    ))}
                </div>
            </div>
        </div>

        <About />
        <Craft />
        <Anatomy />
        <Menu />
        <Locations />
        <Reviews />
    </div>
    <Footer />
</Layout>

<style>
    .marquee-container {
        position: relative;
        z-index: 10;
        margin: -2.6rem 0 4.75rem;
        padding: 1rem 0;
        overflow: hidden;
        border-top: 2px solid rgba(31, 22, 9, 0.22);
        border-bottom: 2px solid rgba(31, 22, 9, 0.22);
        background: var(--brand-orange);
        box-shadow: 0 18px 34px rgba(112, 71, 7, 0.18);
        transform: rotate(-1.2deg) scale(1.03);
    }

    .marquee-track {
        display: flex;
        width: max-content;
        animation: marquee-slide 20s linear infinite;
    }

    .marquee-group {
        display: inline-flex;
        align-items: center;
        white-space: nowrap;
    }

    .marquee-item {
        display: inline-flex;
        align-items: center;
        font-family: var(--font-heading);
        font-size: 1.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        line-height: 1;
    }

    .marquee-item.is-solid {
        color: rgba(38, 24, 11, 0.98);
        text-shadow: 0 1px 0 rgba(255, 245, 224, 0.22);
    }

    .marquee-item.is-tag {
        padding: 0.16rem 0.62rem 0.22rem;
        border-radius: 999px;
        color: #fff5e0;
        background: rgba(38, 24, 11, 0.26);
        border: 1px solid rgba(38, 24, 11, 0.18);
        box-shadow: inset 0 1px 0 rgba(255, 248, 230, 0.14);
    }

    .separator {
        margin: 0 1.5rem;
        color: rgba(38, 24, 11, 0.56);
        font-size: 1rem;
        transform: translateY(-2px);
    }

    @keyframes marquee-slide {
        from {
            transform: translateX(0);
        }

        to {
            transform: translateX(-50%);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .marquee-track {
            animation: none;
        }
    }

    @media (max-width: 900px) {
        .marquee-container {
            margin: -1.35rem 0 4rem;
            padding: 0.8rem 0;
            transform: rotate(-1deg) scale(1.04);
        }

        .marquee-item {
            font-size: 1.2rem;
        }

        .marquee-item.is-tag {
            padding: 0.14rem 0.5rem 0.18rem;
        }

        .separator {
            margin: 0 1rem;
        }
    }
</style>
