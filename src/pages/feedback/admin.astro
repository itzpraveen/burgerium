---
export const prerender = false;

import Footer from '../../components/Footer.astro';
import Navigation from '../../components/Navigation.astro';
import {
    feedbackCategories,
    getScoreColorClass,
    getScoreMeta,
} from '../../lib/feedback';
import { listFeedbackSubmissions } from '../../lib/feedback-store';
import Layout from '../../layouts/Layout.astro';

const submissions = await listFeedbackSubmissions();
const totalResponses = submissions.length;
const averageOverall = totalResponses
    ? Number(
        (
            submissions.reduce((sum, submission) => sum + submission.overall, 0) / totalResponses
        ).toFixed(1)
      )
    : 0;
const averageComposite = totalResponses
    ? Number(
        (
            submissions.reduce((sum, submission) => sum + submission.compositeScore, 0) / totalResponses
        ).toFixed(1)
      )
    : 0;
const contactOptIns = submissions.filter((submission) => submission.contactConsent).length;
const attentionNeeded = submissions.filter(
    (submission) => submission.overall <= 2 || submission.compositeScore <= 2.5
).length;
const lastResponse = submissions[0]?.createdAt;
const formatDate = (value: string) =>
    new Intl.DateTimeFormat('en-IN', {
        dateStyle: 'medium',
        timeStyle: 'short',
    }).format(new Date(value));
---

<Layout
    title="Burgerium Feedback Dashboard"
    description="Internal dashboard for reviewing Burgerium guest feedback."
    robots="noindex,nofollow"
>
    <Navigation />

    <div class="dashboard-page">
        <section class="dashboard-hero">
            <div class="container dashboard-header">
                <div>
                    <span class="eyebrow">Operator dashboard</span>
                    <h1>Feedback collected from the application.</h1>
                    <p>
                        Review live submissions, identify low-score tables fast, and export the running record when
                        needed.
                    </p>
                </div>

                <a href="/feedback/export.csv" class="btn-primary">Export CSV</a>
            </div>
        </section>

        <section class="dashboard-section">
            <div class="container">
                <div class="stats-grid">
                    <article class="stat-card">
                        <span>Total responses</span>
                        <strong>{totalResponses}</strong>
                    </article>
                    <article class="stat-card">
                        <span>Avg overall</span>
                        <strong>{averageOverall}/5</strong>
                    </article>
                    <article class="stat-card">
                        <span>Avg experience</span>
                        <strong>{averageComposite}/5</strong>
                    </article>
                    <article class="stat-card">
                        <span>Contact opt-ins</span>
                        <strong>{contactOptIns}</strong>
                    </article>
                    <article class="stat-card">
                        <span>Needs attention</span>
                        <strong>{attentionNeeded}</strong>
                    </article>
                    <article class="stat-card">
                        <span>Latest entry</span>
                        <strong>{lastResponse ? formatDate(lastResponse) : 'No responses yet'}</strong>
                    </article>
                </div>

                {submissions.length === 0 ? (
                    <div class="empty-state">
                        <strong>No feedback has been collected yet.</strong>
                        <p>The first submission from <code>/feedback</code> will appear here.</p>
                    </div>
                ) : (
                    <div class="submission-grid">
                        {submissions.map((submission) => {
                            const compositeMeta = getScoreMeta(submission.compositeScore);
                            return (
                                <article class="submission-card">
                                    <header class="submission-top">
                                        <div>
                                            <h2>{submission.name}</h2>
                                            <p>{submission.phone}</p>
                                        </div>
                                        <div class="submission-badges">
                                            <span class={`score-pill ${getScoreColorClass(submission.compositeScore)}`}>
                                                {compositeMeta.emoji} {submission.compositeScore}/5
                                            </span>
                                            {submission.contactConsent && <span class="contact-pill">Follow up</span>}
                                        </div>
                                    </header>

                                    <p class="submission-date">{formatDate(submission.createdAt)}</p>

                                    <div class="metric-grid">
                                        {feedbackCategories.map((category) => (
                                            <div class="metric-pill">
                                                <span>{category.shortLabel}</span>
                                                <strong>{submission[category.key]}/5</strong>
                                            </div>
                                        ))}
                                    </div>

                                    <div class="comment-block">
                                        <span>Comments</span>
                                        <p>{submission.comments || 'No additional notes left by the guest.'}</p>
                                    </div>
                                </article>
                            );
                        })}
                    </div>
                )}
            </div>
        </section>
    </div>

    <Footer />
</Layout>

<style>
    .dashboard-page {
        padding-top: calc(var(--header-height) + 1.5rem);
    }

    .dashboard-hero {
        padding: 2rem 0 1.4rem;
    }

    .dashboard-header {
        display: flex;
        justify-content: space-between;
        gap: 1.5rem;
        align-items: end;
        padding: 2rem;
        border-radius: 34px;
        border: 1px solid rgba(75, 47, 10, 0.12);
        background:
            radial-gradient(circle at top right, rgba(250, 162, 39, 0.2), transparent 24%),
            rgba(255, 250, 241, 0.92);
        box-shadow: var(--shadow-soft);
    }

    .eyebrow {
        display: inline-flex;
        padding: 0.35rem 0.75rem;
        border-radius: 999px;
        background: rgba(38, 24, 11, 0.08);
        color: var(--brand-orange-deep);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    .dashboard-header h1 {
        margin-top: 0.95rem;
        font-size: clamp(2.7rem, 6vw, 5rem);
        line-height: 0.95;
    }

    .dashboard-header p {
        max-width: 44rem;
        margin-top: 0.9rem;
        color: var(--text-gray);
        line-height: 1.7;
    }

    .dashboard-section {
        padding: 0 0 5rem;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
    }

    .stat-card,
    .submission-card,
    .empty-state {
        border: 1px solid rgba(75, 47, 10, 0.12);
        background: rgba(255, 251, 243, 0.92);
        box-shadow: var(--shadow-soft);
    }

    .stat-card {
        padding: 1.15rem 1.2rem;
        border-radius: 22px;
    }

    .stat-card span,
    .metric-pill span,
    .comment-block span {
        color: var(--text-muted);
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    .stat-card strong {
        display: block;
        margin-top: 0.45rem;
        font-family: var(--font-heading);
        font-size: 2rem;
        letter-spacing: 0.04em;
    }

    .empty-state {
        margin-top: 1rem;
        padding: 1.5rem;
        border-radius: 24px;
    }

    .empty-state strong {
        display: block;
        margin-bottom: 0.35rem;
    }

    .empty-state p {
        color: var(--text-gray);
    }

    .submission-grid {
        display: grid;
        gap: 1rem;
        margin-top: 1rem;
    }

    .submission-card {
        padding: 1.4rem;
        border-radius: 26px;
    }

    .submission-top {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: start;
    }

    .submission-top h2 {
        font-size: 2rem;
        line-height: 0.9;
    }

    .submission-top p,
    .submission-date,
    .comment-block p {
        color: var(--text-gray);
        line-height: 1.6;
    }

    .submission-badges {
        display: flex;
        flex-wrap: wrap;
        justify-content: end;
        gap: 0.6rem;
    }

    .score-pill,
    .contact-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.45rem 0.75rem;
        border-radius: 999px;
        font-weight: 800;
        font-size: 0.85rem;
    }

    .score-pill.is-great {
        background: rgba(255, 214, 106, 0.48);
    }

    .score-pill.is-good {
        background: rgba(255, 227, 142, 0.48);
    }

    .score-pill.is-okay {
        background: rgba(255, 244, 210, 0.9);
    }

    .score-pill.is-fair {
        background: rgba(246, 219, 175, 0.8);
    }

    .score-pill.is-poor {
        background: rgba(255, 212, 196, 0.92);
    }

    .contact-pill {
        background: rgba(38, 24, 11, 0.08);
    }

    .submission-date {
        margin-top: 0.55rem;
    }

    .metric-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.75rem;
        margin-top: 1rem;
    }

    .metric-pill {
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
        align-items: center;
        padding: 0.8rem 0.9rem;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.76);
        border: 1px solid rgba(75, 47, 10, 0.08);
    }

    .metric-pill strong {
        font-weight: 800;
    }

    .comment-block {
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(75, 47, 10, 0.12);
    }

    @media (max-width: 980px) {
        .dashboard-header,
        .stats-grid,
        .metric-grid {
            grid-template-columns: 1fr;
        }

        .dashboard-header {
            align-items: start;
        }
    }

    @media (max-width: 720px) {
        .dashboard-page {
            padding-top: calc(var(--header-height) + 1rem);
        }

        .dashboard-header,
        .submission-card {
            padding: 1.2rem;
            border-radius: 24px;
        }

        .submission-top {
            flex-direction: column;
        }

        .submission-badges {
            justify-content: start;
        }
    }
</style>
