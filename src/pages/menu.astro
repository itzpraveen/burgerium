---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import DigitalMenu from "../components/DigitalMenu.astro";
import Footer from "../components/Footer.astro";
import { menuSections } from "../data/menu";

const menuStructuredData = {
  "@type": "Menu",
  "@id": "https://www.burgerium.in/menu#menu",
  name: "Burgerium Menu",
  description:
    "Burgerium menu in Chennai with burgers, wraps, subs, bowls, fries, coffee, shakes, coolers, iced treats, and desserts.",
  inLanguage: "en-IN",
  hasMenuSection: menuSections.map((section) => ({
    "@type": "MenuSection",
    name: section.title,
  })),
};
---

<Layout
  title="Burgerium Menu | Burgers, Wraps, Bowls, Coffee & Desserts"
  description="Explore the Burgerium menu for Chennai: chicken burgers, beef burgers, veg burgers, wraps, bowls, fries, milkshakes, coffee, iced treats, and desserts."
  structuredData={menuStructuredData}
>
  <Navigation />
  <div class="menu-page">
    <DigitalMenu />
  </div>
  <Footer />
</Layout>

<style>
  .menu-page {
    min-height: 100vh;
    background: #fff6e4;
  }
</style>
