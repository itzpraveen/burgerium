---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import DigitalMenu from "../components/DigitalMenu.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Burgerium Menu | Burgers, Wraps, Bowls, Coffee & Desserts"
  description="Explore the full Burgerium digital menu for Chennai: chicken burgers, beef burgers, veg burgers, wraps, bowls, fries, milkshakes, coffee, iced treats, and desserts."
>
  <Navigation />
  <div class="menu-page">
    <DigitalMenu />
  </div>
  <Footer />
</Layout>

<style>
  .menu-page {
    min-height: 100vh;
    background: var(--bg-dark);
  }
</style>
